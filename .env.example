# ==========================================
# Astro + Turso + Cloudinary + Contact Email
# Copy this file to .env and fill in values.
# ==========================================

# --- Core app ---
SITE_URL=https://your-domain.com
JWT_SECRET=replace-with-a-long-random-secret

# --- Turso database ---
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=replace-with-your-turso-auth-token

# --- Cloudinary media ---
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# --- Contact form email (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
CONTACT_TO_EMAIL=support@happyfeelingprints.com
# Must be a verified sender/domain in Resend
CONTACT_FROM_EMAIL=no-reply@happyfeelingprints.com

# --- Social share (optional) ---
# PUBLIC_FB_APP_ID enables Facebook Insights traffic analytics for your articles.
# Create a free app at https://developers.facebook.com/apps — Basic setup, no review needed.
# Leave blank to omit the fb:app_id meta tag entirely (sharing still works without it).
PUBLIC_FB_APP_ID=

# --- CDN upload config (optional/advanced) ---
# Keep these only if your current deployment uses CDN PUT uploads.
CDN_UPLOAD_URL=https://storage-provider.example.com/zone
CDN_PUBLIC_URL=https://cdn.example.com
CDN_API_KEY=replace-with-cdn-api-key
