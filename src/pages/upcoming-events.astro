---
import type { CalendarEvent, SaleItem } from "../components/EventCalendar";
import EventCalendar from "../components/EventCalendar";
import BlogLayout from "../layouts/BlogLayout.astro";
import {
  buildCloudinaryImageSrcset,
  buildCloudinaryImageUrl,
} from "../lib/cloudinary";
import { db } from "../lib/db";
import {
  EVENT_SELECT_FIELDS,
  type EventRecord,
  ensureEventsSchema,
  getEventLifecycleLabel,
  isEventArchivable,
  isEventUpcoming,
  mapEventRow,
} from "../lib/events";

const siteUrl = process.env.SITE_URL || Astro.url.origin;
const cloudName = import.meta.env.CLOUDINARY_CLOUD_NAME ?? "";
const canonicalUrl = `${siteUrl}/upcoming-events`;

await ensureEventsSchema();

const result = await db.execute(
  `SELECT ${EVENT_SELECT_FIELDS}
   FROM events e
   LEFT JOIN users u ON u.id = e.owner_id
   LEFT JOIN media m ON m.id = e.featured_media_id
   WHERE e.status = 'published'
   ORDER BY date(e.start_date) ASC,
            COALESCE(time(e.start_time), '23:59') ASC,
            e.created_at DESC`,
);

const allEvents = result.rows.map((row: Record<string, unknown>) =>
  mapEventRow(row),
);

// Separate upcoming and archive events
const upcomingEvents = allEvents.filter(isEventUpcoming);
const archiveEvents = allEvents.filter(isEventArchivable);

// Query active sales for the calendar (promo window overlaps next 90 days)
let calendarSales: SaleItem[] = [];
try {
  const salesResult = await db.execute(
    `SELECT id, slug, title, promo_label, promo_discount_pct,
            promo_start, promo_end, etsy_listing_url,
            etsy_price_amount, etsy_price_divisor, etsy_price_currency
     FROM sales_postings
     WHERE status = 'published'
       AND promo_start IS NOT NULL
       AND promo_end IS NOT NULL
       AND promo_end >= date('now')
       AND promo_start <= date('now', '+90 days')
     ORDER BY promo_start ASC`,
    [],
  );
  calendarSales = salesResult.rows.map((row: Record<string, unknown>) => ({
    id: Number(row.id),
    slug: String(row.slug ?? ""),
    title: String(row.title ?? ""),
    promo_label: row.promo_label == null ? null : String(row.promo_label),
    promo_discount_pct:
      row.promo_discount_pct == null ? null : Number(row.promo_discount_pct),
    promo_start: String(row.promo_start ?? ""),
    promo_end: String(row.promo_end ?? ""),
    etsy_listing_url:
      row.etsy_listing_url == null ? null : String(row.etsy_listing_url),
    etsy_price_amount:
      row.etsy_price_amount == null ? null : Number(row.etsy_price_amount),
    etsy_price_divisor: Number(row.etsy_price_divisor ?? 100),
    etsy_price_currency: String(row.etsy_price_currency ?? "USD"),
  }));
} catch {
  // sales_postings table may not exist in some environments
}

// Map events to CalendarEvent shape for the React island
const calendarEvents: CalendarEvent[] = allEvents
  .filter(isEventUpcoming)
  .map((e: EventRecord) => ({
    id: e.id,
    slug: e.slug,
    title: e.title,
    description: e.description,
    start_date: e.start_date,
    end_date: e.end_date,
    start_time: e.start_time,
    end_time: e.end_time,
    is_all_day: e.is_all_day,
    venue_name: e.venue_name,
    city: e.city,
    color: e.color,
  }));

function formatDate(date: string): string {
  const parsed = new Date(`${date}T00:00:00`);
  if (Number.isNaN(parsed.getTime())) return date;
  return parsed.toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  });
}

function formatTime(time: string | null): string | null {
  if (!time) return null;
  const parsed = new Date(`1970-01-01T${time}:00`);
  if (Number.isNaN(parsed.getTime())) return time;
  return parsed.toLocaleTimeString("en-US", {
    hour: "numeric",
    minute: "2-digit",
  });
}

function getEventImageUrl(
  publicId: string | null,
  fallbackUrl: string | null,
  preset: "hero" | "thumb",
): string | null {
  if (!fallbackUrl) return null;
  if (!publicId || !cloudName) return fallbackUrl;
  try {
    return buildCloudinaryImageUrl({ cloudName, publicId, preset });
  } catch {
    return fallbackUrl;
  }
}

const featuredEvent = upcomingEvents[0] ?? null;
---

<BlogLayout
  title="Upcoming Events — The Happy Feeling Scriptorium"
  description="Upcoming events from The Happy Feeling Scriptorium."
  canonicalUrl={canonicalUrl}
>
  <main class="events-page">
    <section class="events-hero page-wrap">
      <p class="events-eyebrow">Community Calendar</p>
      <h1 class="events-title">Upcoming Events</h1>
      <p class="events-intro">
        Local gallery shows, awareness showcases, sidewalk art sales, and
        small-business collaborative exhibitions led by our artists.
      </p>
    </section>

    {
      featuredEvent && (
        <section
          class="event-featured page-wrap"
          aria-label="Featured upcoming event"
        >
          <div class="event-featured__content">
            <p class="event-featured__label">Happening Next</p>
            <h2 class="event-featured__title">
              <a href={`/events/${featuredEvent.slug}`}>
                {featuredEvent.title}
              </a>
            </h2>
            <p class="event-featured__meta">
              {formatDate(featuredEvent.start_date)}
              {featuredEvent.end_date &&
                ` to ${formatDate(featuredEvent.end_date)}`}
              {featuredEvent.is_all_day
                ? " • All Day"
                : featuredEvent.start_time
                  ? ` • ${formatTime(featuredEvent.start_time)}${featuredEvent.end_time ? ` to ${formatTime(featuredEvent.end_time)}` : ""}`
                  : ""}
            </p>
            {featuredEvent.venue_name && (
              <p class="event-featured__meta event-featured__meta--location">
                {featuredEvent.venue_name}
                {featuredEvent.city && ` • ${featuredEvent.city}`}
              </p>
            )}
            {featuredEvent.description && (
              <p class="event-featured__description">
                {featuredEvent.description}
              </p>
            )}
            <a
              href={`/events/${featuredEvent.slug}`}
              class="event-featured__cta"
            >
              View Event
            </a>
          </div>
          {featuredEvent.featured_media_url && (
            <div class="event-featured__media">
              <img
                src={
                  getEventImageUrl(
                    featuredEvent.featured_media_public_id,
                    featuredEvent.featured_media_url,
                    "hero",
                  ) ?? featuredEvent.featured_media_url!
                }
                srcset={
                  featuredEvent.featured_media_public_id && cloudName
                    ? buildCloudinaryImageSrcset({
                        cloudName,
                        publicId: featuredEvent.featured_media_public_id,
                        preset: "hero",
                      })
                    : undefined
                }
                sizes="(max-width: 768px) 100vw, 1280px"
                alt={
                  featuredEvent.featured_media_alt_text ?? featuredEvent.title
                }
                loading="lazy"
              />
            </div>
          )}
        </section>
      )
    }

    <section class="events-list page-wrap" aria-label="All upcoming events">
      <h2 class="events-section-title">On The Calendar</h2>
      {
        calendarEvents.length === 0 && calendarSales.length === 0 && (
          <p class="events-empty">
            New events are being scheduled. Check back soon for upcoming gallery
            and artist-community gatherings.
          </p>
        )
      }
      {
        (calendarEvents.length > 0 || calendarSales.length > 0) && (
          <EventCalendar
            client:only="react"
            events={calendarEvents}
            sales={calendarSales}
            siteUrl={siteUrl}
          />
        )
      }
    </section>

    {
      archiveEvents.length > 0 && (
        <section
          class="events-archive page-wrap"
          aria-label="Recently ended events"
        >
          <div class="archive-header">
            <h2 class="events-section-title">Recently Ended</h2>
            <p class="archive-intro">
              Events that have recently concluded, saved here for 14 days.
            </p>
            <a href="/events/archive" class="archive-link">
              View Full Archive →
            </a>
          </div>
          {archiveEvents.map((event: (typeof archiveEvents)[0]) => {
            const lifecycleLabel = getEventLifecycleLabel(event);
            const badgeClass =
              lifecycleLabel === "ended" ? "badge--ended" : "badge--archived";
            const badgeText = lifecycleLabel === "ended" ? "Ended" : "Archived";
            return (
              <article class="event-card event-card--archived">
                <div class="event-card__badge-wrap">
                  <span class={`badge ${badgeClass}`}>{badgeText}</span>
                </div>
                <p class="event-card__date">
                  {formatDate(event.start_date)}
                  {event.end_date && ` to ${formatDate(event.end_date)}`}
                </p>
                <h3 class="event-card__title">
                  <a href={`/events/${event.slug}`}>{event.title}</a>
                </h3>
                {event.description && (
                  <p class="event-card__description">{event.description}</p>
                )}
                <a href={`/events/${event.slug}`} class="event-card__cta">
                  View Event
                </a>
              </article>
            );
          })}
        </section>
      )
    }
  </main>
</BlogLayout>

<style>
  @import "../styles/pages/events.css";
</style>
