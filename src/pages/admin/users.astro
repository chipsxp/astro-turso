---
import AdminLayout from "../../layouts/AdminLayout.astro";
const user = Astro.locals.user!;
---

<AdminLayout title="Users">
  <div id="current-user" data-id={user.id} data-role={user.role} hidden></div>
  <div class="page-header">
    <div>
      <p id="page-eyebrow" class="page-header__eyebrow">Access Control</p>
      <h1 class="page-header__title">
        Manage <em>Users</em>
        <span id="pending-count" class="pending-count" style="display:none"
        ></span>
      </h1>
    </div>
  </div>

  <!-- Users table -->
  <div id="state-table" class="card">
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Email</th>
            <th>Role</th>
            <th id="th-status">Status</th>
            <th>Registered</th>
            <th id="th-actions" class="table-actions-col">Actions</th>
          </tr>
        </thead>
        <tbody id="users-tbody"></tbody>
      </table>
    </div>
  </div>

  <!-- Toast -->
  <div id="user-toast" class="user-toast"></div>
</AdminLayout>

<style is:global>
  @import "../../styles/pages/admin-users.css";
</style>

<script>
  type UserRecord = {
    id: number;
    email: string;
    role: "admin" | "author";
    status?: "active" | "pending" | "suspended"; // absent in author (community) view
    created_at: string;
  };

  let currentUserId: number | null = null;
  let currentUserRole: string = "";

  const stateTable = document.getElementById("state-table")!;
  const tbody = document.getElementById("users-tbody")!;
  const pendingCountEl = document.getElementById("pending-count")!;
  const toast = document.getElementById("user-toast")!;

  let toastTimer: number | null = null;

  // Get current user identity from server-rendered data attribute
  (function detectCurrentUser() {
    const el = document.getElementById("current-user");
    currentUserId = el ? Number(el.dataset.id) : null;
    currentUserRole = String(el?.dataset.role ?? "");
  })();

  function showToast(msg: string, isError = false) {
    toast.textContent = msg;
    toast.classList.toggle("user-toast--error", isError);
    toast.classList.add("is-visible");
    if (toastTimer) clearTimeout(toastTimer);
    toastTimer = window.setTimeout(() => {
      toast.classList.remove("is-visible");
    }, 3500);
  }

  function formatDate(iso: string): string {
    if (!iso) return "—";
    try {
      return new Date(iso).toLocaleDateString("en-US", {
        year: "numeric",
        month: "short",
        day: "numeric",
      });
    } catch {
      return iso;
    }
  }

  // Adapt the page header and table columns to the caller's role.
  function applyRoleView(isAdmin: boolean) {
    const eyebrow = document.getElementById("page-eyebrow");
    const thStatus = document.getElementById("th-status");
    const thActions = document.getElementById("th-actions");
    if (!isAdmin) {
      if (eyebrow) eyebrow.textContent = "Your Account";
      if (thStatus) thStatus.style.display = "none";
      if (thActions) thActions.style.display = "none";
      pendingCountEl.style.display = "none";
    }
  }

  function renderUsers(users: UserRecord[], isAdmin: boolean) {
    tbody.innerHTML = "";

    if (isAdmin) {
      const pendingCount = users.filter((u) => u.status === "pending").length;
      pendingCountEl.textContent =
        pendingCount > 0 ? `${pendingCount} pending` : "";
      pendingCountEl.style.display = pendingCount > 0 ? "" : "none";
    }

    for (const u of users) {
      const isSelf = u.id === currentUserId;
      const roleBadge = `<span class="role-badge${u.role === "admin" ? " role-badge--admin" : ""}">${u.role}</span>`;

      // Status and Actions cells are only rendered in the admin view
      const statusCell = isAdmin
        ? `<td><span class="status-badge status-badge--${u.status ?? "active"}">${u.status ?? "active"}</span></td>`
        : "";
      const actionsCell = isAdmin
        ? `<td><div class="action-group">${buildActions(u, isSelf)}</div></td>`
        : "";

      const tr = document.createElement("tr");
      tr.innerHTML = `
        <td>${u.email}${isSelf ? ' <span style="font-size:0.6rem;opacity:0.5;font-family:var(--font-mono)">(you)</span>' : ""}</td>
        <td>${roleBadge}</td>
        ${statusCell}
        <td style="font-family:var(--font-mono);font-size:0.75rem">${formatDate(u.created_at)}</td>
        ${actionsCell}
      `;

      if (isAdmin) {
        tr.querySelectorAll<HTMLButtonElement>("button[data-action]").forEach(
          (btn) => {
            btn.addEventListener("click", () =>
              handleAction(u.id, btn.dataset.action!, btn),
            );
          },
        );
      }

      tbody.appendChild(tr);
    }
  }

  function buildActions(u: UserRecord, isSelf: boolean): string {
    if (isSelf)
      return '<span style="font-size:0.65rem;opacity:0.4;font-family:var(--font-mono)">—</span>';

    const btns: string[] = [];

    if (u.status === "pending") {
      btns.push(
        `<button class="btn-action btn-action--approve" data-action="approve">Approve</button>`,
      );
    }

    if (u.status === "active" && u.role === "author") {
      btns.push(
        `<button class="btn-action btn-action--danger" data-action="suspend">Suspend</button>`,
        `<button class="btn-action btn-action--promote" data-action="promote">Promote to Admin</button>`,
      );
    }

    if (u.status === "suspended") {
      btns.push(
        `<button class="btn-action" data-action="reinstate">Reinstate</button>`,
      );
    }

    if (btns.length === 0) {
      return '<span style="font-size:0.65rem;opacity:0.4;font-family:var(--font-mono)">—</span>';
    }

    return btns.join("");
  }

  async function handleAction(
    userId: number,
    action: string,
    btn: HTMLButtonElement,
  ) {
    btn.disabled = true;
    const original = btn.textContent;
    btn.textContent = "…";

    try {
      const res = await fetch(`/api/admin/users/${userId}`, {
        method: "PATCH",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ action }),
      });

      const data = await res.json();

      if (!res.ok) {
        showToast(data.error ?? "Action failed.", true);
        btn.disabled = false;
        btn.textContent = original;
        return;
      }

      const messages: Record<string, string> = {
        approve: "User approved — they can now log in.",
        suspend: "User suspended.",
        reinstate: "User reinstated.",
        promote: "User promoted to admin.",
      };
      showToast(messages[action] ?? "Done.");
      // Reload the list to reflect changes
      await loadUsers();
    } catch {
      showToast("Network error. Please try again.", true);
      btn.disabled = false;
      btn.textContent = original;
    }
  }

  async function loadUsers() {
    try {
      const res = await fetch("/api/admin/users");

      if (!res.ok) {
        console.error("Failed to load users:", res.status);
        return;
      }

      const data = await res.json();
      const isAdmin = data.isAdmin === true;
      applyRoleView(isAdmin);
      renderUsers(data.users ?? [], isAdmin);
    } catch (err) {
      console.error("Network error loading users:", err);
    }
  }

  loadUsers();
</script>
