---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { db } from "../../../lib/db";

const { slug } = Astro.params;
const user = Astro.locals.user!;

let posting: any = null;
let images: any[] = [];
let testimonials: any[] = [];
let reviews: any[] = [];
let notFound = false;

try {
  const result = await db.execute(
    `SELECT sp.*, u.email AS author_email
     FROM sales_postings sp
     LEFT JOIN users u ON u.id = sp.author_id
     WHERE sp.slug = ?`,
    [slug],
  );

  if (!result.rows.length) {
    notFound = true;
  } else {
    posting = result.rows[0];
    if (
      user.role !== "admin" &&
      Number(posting.author_id) !== Number(user.id)
    ) {
      notFound = true;
    }
  }

  if (!notFound) {
    const [imagesRes, testimonialsRes, reviewsRes] = await Promise.all([
      db.execute(
        "SELECT * FROM sales_images WHERE posting_id = ? ORDER BY sort_order ASC",
        [Number(posting.id)],
      ),
      db.execute(
        "SELECT * FROM sales_testimonials WHERE posting_id = ? ORDER BY sort_order ASC",
        [Number(posting.id)],
      ),
      db.execute(
        "SELECT * FROM sales_reviews WHERE posting_id = ? ORDER BY sort_order ASC",
        [Number(posting.id)],
      ),
    ]);
    images = imagesRes.rows;
    testimonials = testimonialsRes.rows;
    reviews = reviewsRes.rows;
  }
} catch (err: unknown) {
  notFound = true;
}

if (notFound) {
  return Astro.redirect("/admin/sales", 302);
}

const displayPrice =
  posting.etsy_price_amount != null
    ? `${posting.etsy_price_currency} ${(posting.etsy_price_amount / (posting.etsy_price_divisor ?? 100)).toFixed(2)}`
    : "";
---

<AdminLayout title={`Edit: ${posting.title}`}>
  <div class="page-header">
    <div>
      <p class="page-header__eyebrow">Shop</p>
      <h1 class="page-header__title">Edit <em>Sales Posting</em></h1>
    </div>
    <div class="flex" style="gap: 8px; align-items: center;">
      {
        posting.status === "published" && (
          <a href={`/shop/${slug}`} class="btn btn-ghost" target="_blank">
            View Live ↗
          </a>
        )
      }
      <a href="/admin/sales" class="btn btn-ghost">← Back to Postings</a>
    </div>
  </div>

  <div id="toast-container"></div>

  <!-- ── Etsy Import (re-import from browser) ──────────────────────────── -->
  <div class="card card--accent-top" style="margin-bottom: 1.5rem;">
    <div
      style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem;"
    >
      <p class="panel-heading" style="margin: 0;">
        Re-Import from Etsy (Optional)
      </p>
      <button type="button" id="etsy-browse-toggle" class="btn btn-ghost">
        Browse Etsy Store ▾
      </button>
    </div>
    <p
      id="etsy-import-status"
      class="form-hint"
      style="min-height: 1.2em; margin-top: 0.5rem;"
    >
    </p>

    <!-- Browser panel (hidden by default) -->
    <div id="etsy-browser" class="etsy-browser" hidden>
      <div id="etsy-section-tabs" class="etsy-section-tabs">
        <button
          type="button"
          class="etsy-tab etsy-tab--active"
          data-section="all">All</button
        >
      </div>
      <div id="etsy-grid" class="etsy-grid">
        <p class="etsy-loading">Loading…</p>
      </div>
      <div
        id="etsy-load-more-row"
        style="text-align: center; padding: 0.75rem 0; display: none;"
      >
        <button type="button" id="etsy-load-more" class="btn btn-ghost"
          >Load more</button
        >
      </div>
    </div>
  </div>

  <form id="sales-form" novalidate data-slug={posting.slug}>
    <div class="editor-grid">
      <!-- ── Left column ─────────────────────────────────────────────── -->
      <div>
        <div class="card card--accent-top" style="margin-bottom: 1.5rem;">
          <p class="panel-heading">Content</p>

          <div class="form-group">
            <label class="form-label" for="title">Title *Required</label>
            <input
              class="form-input"
              id="title"
              name="title"
              type="text"
              value={posting.title}
              required
            />
          </div>

          <div class="form-group">
            <label class="form-label" for="slug">Slug</label>
            <input
              class="form-input"
              id="slug"
              name="slug"
              type="text"
              value={posting.slug}
            />
          </div>

          <div class="form-group">
            <label class="form-label" for="status">Status</label>
            <select class="form-input" id="status" name="status">
              <option value="draft" selected={posting.status === "draft"}
                >Draft</option
              >
              <option
                value="published"
                selected={posting.status === "published"}>Published</option
              >
            </select>
          </div>

          <div class="form-group form-group--compact">
            <label class="form-label" id="body-label">Body</label>
            <div
              id="body-editor"
              class="form-textarea form-textarea--body quill-editor"
              style="min-height: 260px;"
            >
            </div>
            <input
              type="hidden"
              id="body-input"
              name="body"
              value={posting.body ?? ""}
            />
          </div>
        </div>

        <div class="card" style="margin-bottom: 1.5rem;">
          <p class="panel-heading">Price &amp; Promotion</p>

          <div class="form-group">
            <label class="form-label">Etsy Price (read-only)</label>
            <input
              class="form-input"
              id="etsy-price-display"
              type="text"
              readonly
              value={displayPrice}
            />
            <input
              type="hidden"
              id="etsy-price-amount"
              value={posting.etsy_price_amount ?? ""}
            />
            <input
              type="hidden"
              id="etsy-price-divisor"
              value={posting.etsy_price_divisor ?? 100}
            />
            <input
              type="hidden"
              id="etsy-price-currency"
              value={posting.etsy_price_currency ?? "USD"}
            />
          </div>

          <div class="form-group">
            <label class="form-label" for="etsy-listing-url"
              >Etsy Listing URL</label
            >
            <input
              class="form-input"
              id="etsy-listing-url"
              name="etsy_listing_url"
              type="url"
              value={posting.etsy_listing_url ?? ""}
            />
          </div>

          <div class="form-group">
            <label class="form-label" for="promo-label">Promo Label</label>
            <input
              class="form-input"
              id="promo-label"
              name="promo_label"
              type="text"
              value={posting.promo_label ?? ""}
            />
          </div>

          <div
            class="form-group"
            style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;"
          >
            <div>
              <label class="form-label" for="promo-discount">Discount %</label>
              <input
                class="form-input"
                id="promo-discount"
                name="promo_discount_pct"
                type="number"
                min="0"
                max="100"
                step="0.5"
                value={posting.promo_discount_pct ?? ""}
              />
            </div>
            <div>
              <label class="form-label">Sale Price Preview</label>
              <input
                class="form-input"
                id="sale-price-preview"
                type="text"
                readonly
              />
            </div>
          </div>

          <div
            class="form-group"
            style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;"
          >
            <div>
              <label class="form-label" for="promo-start">Promo Start</label>
              <input
                class="form-input"
                id="promo-start"
                name="promo_start"
                type="datetime-local"
                value={posting.promo_start
                  ? posting.promo_start.slice(0, 16)
                  : ""}
              />
            </div>
            <div>
              <label class="form-label" for="promo-end">Promo End</label>
              <input
                class="form-input"
                id="promo-end"
                name="promo_end"
                type="datetime-local"
                value={posting.promo_end ? posting.promo_end.slice(0, 16) : ""}
              />
            </div>
          </div>

          <p class="form-hint">
            ⚠️ Promo pricing is display-only. Buyer pays Etsy's price at
            checkout.
          </p>
        </div>

        <div class="card" style="margin-bottom: 1.5rem;">
          <p class="panel-heading">PayPal Buy Button (Optional)</p>
          <div class="form-group">
            <label class="form-label" for="paypal-html"
              >Paste PayPal Legacy Button HTML</label
            >
            <textarea
              class="form-input"
              id="paypal-html"
              name="paypal_button_html"
              rows="6">{posting.paypal_button_html ?? ""}</textarea
            >
            <span class="form-hint"
              >Only legacy form-based buttons are supported.</span
            >
          </div>
        </div>

        <button
          type="submit"
          id="submit-btn"
          class="btn btn-primary"
          style="width: 100%;">Save Changes</button
        >
      </div>

      <!-- ── Right column ────────────────────────────────────────────── -->
      <div>
        <div class="card" style="margin-bottom: 1.5rem;">
          <p class="panel-heading">Images</p>
          <div id="images-list" class="sales-images-grid"></div>
          <p
            class="form-hint"
            id="images-hint"
            style={images.length > 0 ? "display:none" : ""}
          >
            No images yet. Re-import from Etsy to load images.
          </p>
          <input
            type="hidden"
            id="images-json"
            name="images_json"
            value={JSON.stringify(images)}
          />
        </div>

        <div class="card" style="margin-bottom: 1.5rem;">
          <p class="panel-heading">Testimonials</p>
          <div id="testimonials-list"></div>
          <button
            type="button"
            id="add-testimonial-btn"
            class="btn btn-ghost"
            style="margin-top: 0.5rem;">+ Add Testimonial</button
          >
          <input
            type="hidden"
            id="testimonials-json"
            name="testimonials_json"
            value={JSON.stringify(testimonials)}
          />
        </div>

        <div class="card" style="margin-bottom: 1.5rem;">
          <p class="panel-heading">Reviews</p>
          <div id="reviews-list"></div>
          <button
            type="button"
            id="add-review-btn"
            class="btn btn-ghost"
            style="margin-top: 0.5rem;">+ Add Review</button
          >
          <input
            type="hidden"
            id="reviews-json"
            name="reviews_json"
            value={JSON.stringify(reviews)}
          />
        </div>

        <div class="card" style="margin-bottom: 1.5rem;">
          <p class="panel-heading">Linked Article (Optional)</p>
          <div class="form-group">
            <label class="form-label" for="linked-article">Article Slug</label>
            <input
              class="form-input"
              id="linked-article"
              name="linked_article_slug"
              type="text"
              value={posting.linked_article_slug ?? ""}
              placeholder="e.g. my-article-slug"
            />
          </div>
        </div>
      </div>
    </div>
  </form>
</AdminLayout>

<script>
  import {
    createToastManager,
    escapeAttr,
    escapeHtml,
    initializeEditor,
  } from "../../../lib/editor-utils";

  // ── Types ─────────────────────────────────────────────────────────────────
  interface SalesImage {
    url: string;
    alt_text: string;
    source?: string;
    sort_order?: number;
  }
  interface SalesTestimonial {
    id?: number;
    author_name: string;
    quote: string;
    rating: number | null;
  }
  interface SalesReview {
    id?: number;
    reviewer_name: string;
    review_text: string;
    rating: number | null;
    is_verified: boolean;
    review_date: string;
  }
  interface EtsySection {
    id: number;
    title: string;
  }
  interface EtsyListing {
    listing_id: number;
    title: string;
    thumbnail_url?: string;
    price_display: string;
    quantity?: number;
  }
  interface BrowseResponse {
    sections?: EtsySection[];
    listings?: EtsyListing[];
    has_more: boolean;
    error?: string;
  }

  // ── DOM helper ────────────────────────────────────────────────────────────
  function getEl<T extends HTMLElement>(id: string): T {
    const el = document.querySelector<T>(`#${id}`);
    if (!el) throw new Error(`Element #${id} not found`);
    return el;
  }

  const toast = createToastManager();

  // Read server-rendered values from pre-populated DOM inputs
  const initialBody = getEl<HTMLInputElement>("body-input").value;
  const currentSlug = getEl<HTMLFormElement>("sales-form").dataset.slug ?? "";

  let etsyListingId: string | null = null;
  let currentImages: SalesImage[] = JSON.parse(
    getEl<HTMLInputElement>("images-json").value || "[]",
  );
  let currentTestimonials: SalesTestimonial[] = JSON.parse(
    getEl<HTMLInputElement>("testimonials-json").value || "[]",
  );
  let currentReviews: SalesReview[] = JSON.parse(
    getEl<HTMLInputElement>("reviews-json").value || "[]",
  );

  // ── Quill ─────────────────────────────────────────────────────────────────
  const editor = initializeEditor({
    containerId: "body-editor",
    placeholder: "Describe this item…",
    onContentChange: (html: string) => {
      getEl<HTMLInputElement>("body-input").value = html;
    },
  });
  // Pre-populate without triggering onContentChange (edit page pattern from CLAUDE.md)
  editor.root.innerHTML = initialBody ?? "";
  getEl<HTMLInputElement>("body-input").value = initialBody ?? "";

  // ── Sale price preview ────────────────────────────────────────────────────
  const discountInput = getEl<HTMLInputElement>("promo-discount");
  const salePricePreview = getEl<HTMLInputElement>("sale-price-preview");
  const etsyPriceAmountInput = getEl<HTMLInputElement>("etsy-price-amount");
  const etsyPriceDivisorInput = getEl<HTMLInputElement>("etsy-price-divisor");
  const etsyPriceCurrencyInput = getEl<HTMLInputElement>("etsy-price-currency");

  function updateSalePricePreview(): void {
    const amount = parseFloat(etsyPriceAmountInput.value);
    const divisor = parseFloat(etsyPriceDivisorInput.value) || 100;
    const currency = etsyPriceCurrencyInput.value || "USD";
    const pct = parseFloat(discountInput.value);
    if (isNaN(amount) || isNaN(pct) || pct <= 0) {
      salePricePreview.value = "";
      return;
    }
    const saleVal = (amount / divisor) * (1 - pct / 100);
    try {
      salePricePreview.value = new Intl.NumberFormat("en-US", {
        style: "currency",
        currency,
      }).format(saleVal);
    } catch {
      salePricePreview.value = `${currency} ${saleVal.toFixed(2)}`;
    }
  }
  discountInput.addEventListener("input", updateSalePricePreview);
  updateSalePricePreview();

  // ── Etsy Product Browser ──────────────────────────────────────────────────
  let browserOffset = 0;
  let browserSectionId = "all";
  let browserPanelOpen = false;
  let selectedListingId: number | null = null;

  const browseToggleBtn = getEl<HTMLButtonElement>("etsy-browse-toggle");
  const browserPanel = getEl<HTMLElement>("etsy-browser");
  const sectionTabsEl = getEl<HTMLElement>("etsy-section-tabs");
  const gridEl = getEl<HTMLElement>("etsy-grid");
  const loadMoreRow = getEl<HTMLElement>("etsy-load-more-row");
  const loadMoreBtn = getEl<HTMLButtonElement>("etsy-load-more");
  const importStatus = getEl<HTMLElement>("etsy-import-status");

  browseToggleBtn.addEventListener("click", async () => {
    browserPanelOpen = !browserPanelOpen;
    browserPanel.hidden = !browserPanelOpen;
    browseToggleBtn.textContent = browserPanelOpen
      ? "Browse Etsy Store ▴"
      : "Browse Etsy Store ▾";
    if (browserPanelOpen && gridEl.querySelector(".etsy-loading")) {
      await loadBrowser(true);
    }
  });

  async function loadBrowser(reset: boolean): Promise<void> {
    if (reset) {
      browserOffset = 0;
      gridEl.innerHTML = `<p class="etsy-loading">Loading…</p>`;
      loadMoreRow.style.display = "none";
    }
    importStatus.textContent = "";

    const url = `/api/admin/sales/etsy-browse?section_id=${browserSectionId}&offset=${browserOffset}&limit=24`;
    let data: BrowseResponse;
    try {
      const res = await fetch(url);
      data = await res.json();
      if (!res.ok) {
        gridEl.innerHTML = `<p class="etsy-error">⚠️ ${data.error ?? "Failed to load listings."}</p>`;
        loadMoreRow.style.display = "none";
        return;
      }
    } catch {
      gridEl.innerHTML = `<p class="etsy-error">⚠️ Network error — could not reach the server.</p>`;
      loadMoreRow.style.display = "none";
      return;
    }

    if (
      reset &&
      browserOffset === 0 &&
      Array.isArray(data.sections) &&
      data.sections.length > 0
    ) {
      renderSectionTabs(data.sections);
    }

    const cards = renderCards(data.listings ?? []);
    if (reset) gridEl.innerHTML = "";
    if (cards.length === 0 && browserOffset === 0) {
      gridEl.innerHTML = `<p class="etsy-empty">No active listings found.</p>`;
    } else {
      cards.forEach((card) => gridEl.appendChild(card));
    }

    browserOffset += (data.listings ?? []).length;
    loadMoreRow.style.display = data.has_more ? "block" : "none";
  }

  function renderSectionTabs(sections: EtsySection[]): void {
    sectionTabsEl.innerHTML = `<button type="button" class="etsy-tab etsy-tab--active" data-section="all">All</button>`;
    sections.forEach((sec) => {
      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = "etsy-tab";
      btn.dataset.section = String(sec.id);
      btn.textContent = sec.title;
      sectionTabsEl.appendChild(btn);
    });
    sectionTabsEl
      .querySelectorAll<HTMLButtonElement>(".etsy-tab")
      .forEach((tab) => {
        tab.addEventListener("click", async () => {
          sectionTabsEl
            .querySelectorAll<HTMLButtonElement>(".etsy-tab")
            .forEach((t) => t.classList.remove("etsy-tab--active"));
          tab.classList.add("etsy-tab--active");
          browserSectionId = tab.dataset.section ?? "all";
          await loadBrowser(true);
        });
      });
  }

  function renderCards(listings: EtsyListing[]): HTMLButtonElement[] {
    return listings.map((item) => {
      const card = document.createElement("button");
      card.type = "button";
      card.className = "etsy-card";
      if (item.listing_id === selectedListingId)
        card.classList.add("etsy-card--selected");
      card.dataset.listingId = String(item.listing_id);
      card.innerHTML = `
        ${item.thumbnail_url ? `<img src="${escapeAttr(item.thumbnail_url)}" alt="${escapeAttr(item.title)}" class="etsy-card__img" loading="lazy" />` : `<div class="etsy-card__no-img">No image</div>`}
        <span class="etsy-card__title">${escapeHtml(item.title)}</span>
        <span class="etsy-card__price">${escapeHtml(item.price_display)}</span>
        ${item.quantity != null && item.quantity <= 3 ? `<span class="etsy-card__qty">Only ${item.quantity} left</span>` : ""}
      `;
      card.addEventListener("click", () => importCard(item.listing_id, card));
      return card;
    });
  }

  async function importCard(
    listingId: number,
    cardEl: HTMLButtonElement,
  ): Promise<void> {
    const confirmed = window.confirm(
      "Re-importing will replace the current title, body, price, and images. Continue?",
    );
    if (!confirmed) return;

    importStatus.textContent = "Importing…";
    gridEl
      .querySelectorAll<HTMLButtonElement>(".etsy-card--selected")
      .forEach((c) => c.classList.remove("etsy-card--selected"));
    cardEl.classList.add("etsy-card--selected");
    selectedListingId = listingId;

    try {
      const res = await fetch("/api/admin/sales/etsy-import", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ listing_id: listingId }),
      });
      const data = await res.json();
      if (!res.ok) {
        importStatus.textContent = `Error: ${data.error}`;
        cardEl.classList.remove("etsy-card--selected");
        selectedListingId = null;
        return;
      }
      etsyListingId = data.listing_id;
      getEl<HTMLInputElement>("title").value = data.title;
      editor.root.innerHTML = data.body_html;
      getEl<HTMLInputElement>("body-input").value = data.body_html;
      getEl<HTMLInputElement>("etsy-listing-url").value = data.listing_url;
      if (data.price_amount != null) {
        etsyPriceAmountInput.value = String(data.price_amount);
        etsyPriceDivisorInput.value = String(data.price_divisor);
        etsyPriceCurrencyInput.value = data.price_currency;
        getEl<HTMLInputElement>("etsy-price-display").value =
          `${data.price_currency} ${(data.price_amount / data.price_divisor).toFixed(2)}`;
        updateSalePricePreview();
      }
      currentImages = data.images ?? [];
      renderImages();
      importStatus.textContent = `✓ Re-imported "${data.title}" with ${currentImages.length} image(s).`;
    } catch {
      importStatus.textContent = "Network error.";
      cardEl.classList.remove("etsy-card--selected");
      selectedListingId = null;
    }
  }

  loadMoreBtn.addEventListener("click", async () => {
    await loadBrowser(false);
  });

  // ── Images ────────────────────────────────────────────────────────────────
  const imagesListEl = getEl<HTMLElement>("images-list");
  const imagesHintEl = getEl<HTMLElement>("images-hint");
  const imagesJsonEl = getEl<HTMLInputElement>("images-json");

  function renderImages(): void {
    imagesListEl.innerHTML = currentImages
      .map(
        (img: SalesImage, i: number) => `
      <div class="sales-image-item">
        <img src="${escapeAttr(img.url)}" alt="${escapeAttr(img.alt_text || "")}" />
        <button type="button" class="sales-image-remove js-remove-image" data-idx="${i}">✕</button>
      </div>`,
      )
      .join("");
    imagesHintEl.style.display = currentImages.length ? "none" : "";
    imagesJsonEl.value = JSON.stringify(currentImages);
  }

  // Event delegation — one listener for the whole list, not one per item
  imagesListEl.addEventListener("click", (e) => {
    const btn = (e.target as Element).closest<HTMLButtonElement>(
      ".js-remove-image",
    );
    if (!btn) return;
    currentImages.splice(Number(btn.dataset.idx), 1);
    renderImages();
  });

  renderImages();

  // ── Testimonials ──────────────────────────────────────────────────────────
  const testimonialsListEl = getEl<HTMLElement>("testimonials-list");
  const testimonialsJsonEl = getEl<HTMLInputElement>("testimonials-json");

  function renderTestimonials(): void {
    testimonialsListEl.innerHTML = currentTestimonials
      .map(
        (t: SalesTestimonial, i: number) => `
      <div class="sub-item">
        <input class="form-input" placeholder="Name" value="${escapeAttr(t.author_name || "")}" data-field="author_name" data-idx="${i}" />
        <textarea class="form-input" placeholder="Quote" rows="2" data-field="quote" data-idx="${i}">${escapeHtml(t.quote || "")}</textarea>
        <input class="form-input" type="number" min="1" max="5" placeholder="Rating" value="${t.rating ?? ""}" data-field="rating" data-idx="${i}" />
        <button type="button" class="btn btn-ghost btn--sm js-remove-testimonial" data-idx="${i}">Remove</button>
      </div>`,
      )
      .join("");
    testimonialsJsonEl.value = JSON.stringify(currentTestimonials);
  }

  // Event delegation — one listener for input changes, one for remove clicks
  testimonialsListEl.addEventListener("input", (e) => {
    const el = e.target as HTMLInputElement | HTMLTextAreaElement;
    const idx = Number(el.dataset.idx);
    const field = el.dataset.field;
    if (!field || isNaN(idx)) return;
    const value = el.value;
    if (field === "rating") {
      currentTestimonials[idx].rating = value ? Number(value) : null;
    } else if (field === "author_name") {
      currentTestimonials[idx].author_name = value;
    } else if (field === "quote") {
      currentTestimonials[idx].quote = value;
    }
    testimonialsJsonEl.value = JSON.stringify(currentTestimonials);
  });
  testimonialsListEl.addEventListener("click", (e) => {
    const btn = (e.target as Element).closest<HTMLButtonElement>(
      ".js-remove-testimonial",
    );
    if (!btn) return;
    currentTestimonials.splice(Number(btn.dataset.idx), 1);
    renderTestimonials();
  });

  getEl<HTMLButtonElement>("add-testimonial-btn").addEventListener(
    "click",
    () => {
      currentTestimonials.push({ author_name: "", quote: "", rating: null });
      renderTestimonials();
    },
  );
  renderTestimonials();

  // ── Reviews ───────────────────────────────────────────────────────────────
  const reviewsListEl = getEl<HTMLElement>("reviews-list");
  const reviewsJsonEl = getEl<HTMLInputElement>("reviews-json");

  function renderReviews(): void {
    reviewsListEl.innerHTML = currentReviews
      .map(
        (r: SalesReview, i: number) => `
      <div class="sub-item">
        <input class="form-input" placeholder="Reviewer Name" value="${escapeAttr(r.reviewer_name || "")}" data-field="reviewer_name" data-idx="${i}" />
        <textarea class="form-input" rows="2" placeholder="Review text" data-field="review_text" data-idx="${i}">${escapeHtml(r.review_text || "")}</textarea>
        <input class="form-input" type="number" min="1" max="5" placeholder="Rating" value="${r.rating ?? ""}" data-field="rating" data-idx="${i}" />
        <label><input type="checkbox" data-field="is_verified" data-idx="${i}" ${r.is_verified ? "checked" : ""} /> Verified Buyer</label>
        <input class="form-input" type="date" value="${r.review_date ?? ""}" data-field="review_date" data-idx="${i}" />
        <button type="button" class="btn btn-ghost btn--sm js-remove-review" data-idx="${i}">Remove</button>
      </div>`,
      )
      .join("");
    reviewsJsonEl.value = JSON.stringify(currentReviews);
  }

  // Event delegation — input/change events bubble up to the container
  reviewsListEl.addEventListener("input", (e) => {
    const el = e.target as HTMLInputElement | HTMLTextAreaElement;
    const idx = Number(el.dataset.idx);
    const field = el.dataset.field;
    if (!field || isNaN(idx)) return;
    const value = el.value;
    if (field === "rating") {
      currentReviews[idx].rating = value ? Number(value) : null;
    } else if (field === "reviewer_name") {
      currentReviews[idx].reviewer_name = value;
    } else if (field === "review_text") {
      currentReviews[idx].review_text = value;
    } else if (field === "review_date") {
      currentReviews[idx].review_date = value;
    }
    reviewsJsonEl.value = JSON.stringify(currentReviews);
  });
  reviewsListEl.addEventListener("change", (e) => {
    const el = e.target as HTMLInputElement;
    const idx = Number(el.dataset.idx);
    const field = el.dataset.field;
    if (field === "is_verified" && !isNaN(idx)) {
      currentReviews[idx].is_verified = el.checked;
      reviewsJsonEl.value = JSON.stringify(currentReviews);
    }
  });
  reviewsListEl.addEventListener("click", (e) => {
    const btn = (e.target as Element).closest<HTMLButtonElement>(
      ".js-remove-review",
    );
    if (!btn) return;
    currentReviews.splice(Number(btn.dataset.idx), 1);
    renderReviews();
  });

  getEl<HTMLButtonElement>("add-review-btn").addEventListener("click", () => {
    currentReviews.push({
      reviewer_name: "",
      review_text: "",
      rating: null,
      is_verified: false,
      review_date: "",
    });
    renderReviews();
  });
  renderReviews();

  // ── Form submission ───────────────────────────────────────────────────────
  getEl<HTMLFormElement>("sales-form").addEventListener("submit", async (e) => {
    e.preventDefault();
    const title = getEl<HTMLInputElement>("title").value.trim();
    if (!title) {
      toast.show("Title is required.", "error");
      return;
    }

    const body = {
      title,
      slug: getEl<HTMLInputElement>("slug").value.trim() || undefined,
      status: getEl<HTMLSelectElement>("status").value,
      body: getEl<HTMLInputElement>("body-input").value,
      etsy_listing_id: etsyListingId ?? undefined,
      etsy_listing_url:
        getEl<HTMLInputElement>("etsy-listing-url").value || null,
      etsy_price_amount: etsyPriceAmountInput.value
        ? Number(etsyPriceAmountInput.value)
        : undefined,
      etsy_price_divisor: Number(etsyPriceDivisorInput.value) || 100,
      etsy_price_currency: etsyPriceCurrencyInput.value || "USD",
      promo_label: getEl<HTMLInputElement>("promo-label").value || null,
      promo_discount_pct: discountInput.value
        ? Number(discountInput.value)
        : null,
      promo_start: getEl<HTMLInputElement>("promo-start").value || null,
      promo_end: getEl<HTMLInputElement>("promo-end").value || null,
      paypal_button_html:
        getEl<HTMLTextAreaElement>("paypal-html").value || null,
      linked_article_slug:
        getEl<HTMLInputElement>("linked-article").value || null,
      images: currentImages,
    };

    const submitBtn = getEl<HTMLButtonElement>("submit-btn");
    submitBtn.disabled = true;
    submitBtn.textContent = "Saving…";

    try {
      const res = await fetch(`/api/admin/sales/${currentSlug}`, {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body),
      });
      const data = await res.json();
      if (!res.ok) {
        toast.show(data.error ?? "Failed to save.", "error");
        submitBtn.disabled = false;
        submitBtn.textContent = "Save Changes";
        return;
      }

      // Create new testimonials and reviews concurrently
      await Promise.all([
        ...currentTestimonials
          .filter((t) => !t.id && t.author_name && t.quote)
          .map((t) =>
            fetch(`/api/admin/sales/${currentSlug}/testimonials`, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(t),
            }),
          ),
        ...currentReviews
          .filter((r) => !r.id && r.reviewer_name && r.review_text)
          .map((r) =>
            fetch(`/api/admin/sales/${currentSlug}/reviews`, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(r),
            }),
          ),
      ]);

      toast.show("Saved!", "success");
      submitBtn.disabled = false;
      submitBtn.textContent = "Save Changes";
      const newSlug = body.slug ?? currentSlug;
      if (newSlug !== currentSlug) {
        window.location.href = `/admin/sales/${newSlug}`;
      }
    } catch {
      toast.show("Network error.", "error");
      submitBtn.disabled = false;
      submitBtn.textContent = "Save Changes";
    }
  });
</script>

