---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { db } from "../../../lib/db";

const user = Astro.locals.user!;
const isAdmin = user.role === "admin";

let postings: any[] = [];
let fetchError = false;
let fetchErrorDetail = "";
try {
  const result = isAdmin
    ? await db.execute(
        `SELECT sp.*, u.email AS author_email
         FROM sales_postings sp
         LEFT JOIN users u ON u.id = sp.author_id
         ORDER BY sp.created_at DESC`,
        [],
      )
    : await db.execute(
        `SELECT sp.*, u.email AS author_email
         FROM sales_postings sp
         LEFT JOIN users u ON u.id = sp.author_id
         WHERE sp.author_id = ?
         ORDER BY sp.created_at DESC`,
        [Number(user.id)],
      );
  postings = result.rows;
} catch (err: unknown) {
  fetchError = true;
  fetchErrorDetail = err instanceof Error ? err.message : String(err);
}
---

<AdminLayout title="Sales Postings">
  <div class="page-header">
    <div>
      <p class="page-header__eyebrow">Shop</p>
      <h1 class="page-header__title">Sales <em>Postings</em></h1>
    </div>
    <div class="flex" style="gap: 8px; align-items: center;">
      <a href="/admin/sales/new" class="btn btn-primary">+ New Posting</a>
      <a href="/admin/dashboard" class="btn btn-ghost">← Back</a>
    </div>
  </div>

  {
    fetchError && (
      <div class="alert alert--error">
        Could not load sales postings. Please refresh.
        {fetchErrorDetail && (
          <span style="display:block;font-size:0.8rem;margin-top:0.25rem;font-family:monospace;">
            {fetchErrorDetail}
          </span>
        )}
      </div>
    )
  }

  {
    !fetchError && postings.length === 0 && (
      <div class="card" style="padding: 2rem; text-align: center;">
        <p style="color: var(--color-muted);">No sales postings yet.</p>
        <a
          href="/admin/sales/new"
          class="btn btn-primary"
          style="margin-top: 1rem;"
        >
          Create Your First Posting
        </a>
      </div>
    )
  }

  {
    !fetchError && postings.length > 0 && (
      <div id="state-table" class="card">
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Title</th>
                <th>Status</th>
                <th>Price</th>
                <th>Author</th>
                <th>Updated</th>
                <th class="table-actions-col">Actions</th>
              </tr>
            </thead>
            <tbody>
              {postings.map((p) => {
                const price =
                  p.price != null ? `$${Number(p.price).toFixed(2)}` : "—";
                const updated = new Date(p.updated_at).toLocaleDateString(
                  "en-US",
                  { month: "short", day: "numeric", year: "numeric" },
                );
                return (
                  <tr>
                    <td>
                      <a
                        href={`/admin/sales/${p.slug}`}
                        class="dashboard-article-link"
                      >
                        {p.title}
                      </a>
                      <div class="dashboard-article-slug">/shop/{p.slug}</div>
                    </td>
                    <td>
                      <span class={`badge badge--${p.status}`}>
                        {p.status === "published" ? "P" : "D"}
                      </span>
                    </td>
                    <td class="dashboard-price-cell">{price}</td>
                    <td class="dashboard-author-cell">
                      {p.author_email ?? "—"}
                    </td>
                    <td class="dashboard-date-cell">{updated}</td>
                    <td class="table-actions-col">
                      <div class="dashboard-actions-wrap">
                        <a
                          href={`/admin/sales/${p.slug}`}
                          class="btn btn-ghost dashboard-action-btn"
                        >
                          Edit
                        </a>
                        {p.status === "published" ? (
                          <a
                            href={`/shop/${p.slug}`}
                            class="btn btn-ghost dashboard-action-btn"
                            target="_blank"
                          >
                            View
                          </a>
                        ) : (
                          <span
                            class="btn btn-ghost dashboard-action-btn"
                            style="opacity:0.45;cursor:default;"
                            aria-disabled="true"
                          >
                            Draft
                          </span>
                        )}
                        <button
                          class="btn btn-danger dashboard-action-btn js-delete-posting"
                          data-slug={p.slug}
                          data-title={p.title}
                          type="button"
                        >
                          Delete
                        </button>
                      </div>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>
    )
  }
</AdminLayout>

<script>
  document
    .querySelectorAll<HTMLButtonElement>(".js-delete-posting")
    .forEach((btn) => {
      btn.addEventListener("click", async () => {
        const slug = btn.dataset.slug!;
        const title = btn.dataset.title!;
        if (!confirm(`Delete "${title}"? This cannot be undone.`)) return;
        btn.disabled = true;
        try {
          const res = await fetch(`/api/admin/sales/${slug}`, {
            method: "DELETE",
          });
          if (res.ok) {
            btn.closest("tr")?.remove();
          } else {
            const data = await res.json().catch(() => ({}));
            alert(data.error ?? "Failed to delete posting.");
            btn.disabled = false;
          }
        } catch {
          alert("Network error. Please try again.");
          btn.disabled = false;
        }
      });
    });
</script>

<style is:global>
  @import "../../../styles/pages/admin-sales-dashboard.css";
</style>
