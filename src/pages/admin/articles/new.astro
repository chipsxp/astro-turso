---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="New Article">
  <div class="page-header">
    <div>
      <p class="page-header__eyebrow">Articles</p>
      <h1 class="page-header__title">New <em>Article</em></h1>
    </div>
    <div class="flex" style="gap: 8px; align-items: center;">
      <button type="button" id="preview-btn" class="btn btn-ghost"
        >Preview Draft</button
      >
      <a href="/admin/dashboard" class="btn btn-ghost">← Back</a>
    </div>
  </div>

  <form id="article-form" novalidate>
    <div class="editor-grid">
      <!-- Left column: main content panel -->
      <div>
        <div class="card card--accent-top">
          <p class="panel-heading">Content</p>

          <div class="form-group">
            <label class="form-label" for="title">Title *Requred</label>
            <input
              class="form-input"
              id="title"
              name="title"
              type="text"
              placeholder="Article title"
              required
            />
          </div>

          <div class="form-group">
            <label class="form-label" for="slug">Slug</label>
            <input
              class="form-input"
              id="slug"
              name="slug"
              type="text"
              placeholder="auto-generated-from-title"
            />
            <span class="form-hint"
              >Leave blank to auto-generate from title</span
            >
          </div>

          <div class="form-group form-group--compact">
            <label class="form-label" for="body">Body *Required</label>
            <div class="editor-toolbar" aria-label="Body editor toolbar">
              <button
                type="button"
                class="editor-toolbar__btn"
                data-editor-action="bold">Bold</button
              >
              <button
                type="button"
                class="editor-toolbar__btn"
                data-editor-action="italic">Italic</button
              >
              <button
                type="button"
                class="editor-toolbar__btn"
                data-editor-action="link">Link</button
              >
              <button
                type="button"
                class="editor-toolbar__btn"
                data-editor-action="quote">Quote</button
              >
              <button
                type="button"
                class="editor-toolbar__btn"
                data-editor-action="heading">Heading</button
              >
              <button
                type="button"
                class="editor-toolbar__btn"
                data-editor-action="underline">Underline</button
              >
              <button
                type="button"
                class="editor-toolbar__btn"
                data-editor-action="unordered-list">Bulleted List</button
              >
              <button
                type="button"
                class="editor-toolbar__btn"
                data-editor-action="ordered-list">Numbered List</button
              >
              <label class="editor-toolbar__color-wrap" for="editor-text-color">
                Text Color
                <input
                  id="editor-text-color"
                  class="editor-toolbar__color"
                  type="color"
                  value="#6f89ff"
                  aria-label="Choose text color"
                />
              </label>
              <button
                type="button"
                class="editor-toolbar__btn"
                data-editor-action="color">Apply Color</button
              >
              <label class="editor-toolbar__color-wrap" for="editor-bg-color">
                Background
                <input
                  id="editor-bg-color"
                  class="editor-toolbar__color"
                  type="color"
                  value="#f8e040"
                  aria-label="Choose background color"
                />
              </label>
              <button
                type="button"
                class="editor-toolbar__btn"
                data-editor-action="background-color">Apply Background</button
              >
              <button
                type="button"
                class="editor-toolbar__btn"
                data-editor-action="undo-checkpoint">Undo Step</button
              >
              <button
                type="button"
                class="editor-toolbar__btn"
                data-editor-action="font-size-decrease">A-</button
              >
              <button
                type="button"
                class="editor-toolbar__btn"
                data-editor-action="font-size-increase">A+</button
              >
              <button
                type="button"
                class="editor-toolbar__btn"
                data-editor-action="clear-inline">Clear Inline</button
              >
              <button
                type="button"
                class="editor-toolbar__btn"
                data-editor-action="image-inline">Image Inline</button
              >
              <button
                type="button"
                class="editor-toolbar__btn"
                data-editor-action="image-block">Image Block</button
              >
            </div>
            <textarea
              class="form-textarea form-textarea--body"
              id="body"
              name="body"
              placeholder="Write your article content here…"
              required></textarea>
            <details
              class="editor-shortcuts"
              aria-label="Editor keyboard shortcuts"
              open
            >
              <summary class="editor-shortcuts__title">Keyboard hints</summary>
              <table class="editor-shortcuts__table">
                <tbody>
                  <tr>
                    <th scope="row">Enter</th>
                    <td>Create next list item</td>
                  </tr>
                  <tr>
                    <th scope="row">Enter on empty item</th>
                    <td>Exit current list</td>
                  </tr>
                  <tr>
                    <th scope="row">Tab</th>
                    <td>Indent selected list item</td>
                  </tr>
                  <tr>
                    <th scope="row">Shift + Tab</th>
                    <td>Outdent selected list item</td>
                  </tr>
                  <tr>
                    <th scope="row">Paste list text</th>
                    <td>Auto-convert into ul/ol markup</td>
                  </tr>
                  <tr>
                    <th scope="row">Ctrl/Cmd + Z</th>
                    <td>Undo previous checkpoint</td>
                  </tr>
                  <tr>
                    <th scope="row">Ctrl/Cmd + Shift + Z</th>
                    <td>Redo checkpoint</td>
                  </tr>
                </tbody>
              </table>
            </details>
            <input
              id="editor-local-image-file"
              class="is-hidden"
              type="file"
              accept="image/jpeg,image/png,image/webp,image/gif,image/avif"
            />
          </div>
        </div>
      </div>

      <!-- Right column: meta panels -->
      <div class="meta-stack">
        <!-- Publish panel -->
        <div class="card card--accent-top">
          <p class="panel-heading">Publish</p>

          <div class="form-group">
            <label class="form-label" for="category">Category</label>
            <select class="form-select" id="category" name="category">
              <option value="">Uncategorized</option>
            </select>
          </div>

          <div class="form-group">
            <label class="form-label" for="status">Status</label>
            <select class="form-select" id="status" name="status">
              <option value="draft">Draft</option>
              <option value="published">Published</option>
            </select>
          </div>

          <button class="btn-cta" type="submit" id="submit-btn">
            Create Article
          </button>
        </div>

        <!-- SEO fields panel -->
        <div class="card card--kirby-top">
          <p class="panel-heading">SEO Fields</p>

          <div class="form-group">
            <label class="form-label" for="description">Meta Description</label>
            <textarea
              class="form-textarea form-textarea--meta"
              id="description"
              name="description"
              placeholder="Brief description for search engines and social share previews…"
            ></textarea>
            <span class="form-hint">Recommended: 120–160 characters</span>
          </div>

          <div class="form-group form-group--compact">
            <label class="form-label" for="tags">Tags / Labels</label>
            <input
              class="form-input"
              id="tags"
              name="tags"
              type="text"
              placeholder="keyword, topic, label"
            />
            <span class="form-hint">Comma-separated</span>
          </div>
        </div>

        <!-- Image upload panel -->
        <div class="card media-panel" id="image-panel">
          <p class="panel-heading">Images</p>
          <p class="media-panel__note">
            Upload images before or after Create Article.
          </p>
          <div id="upload-area">
            <div class="form-group">
              <label class="form-label" for="img-file">Image File</label>
              <input
                class="form-input form-input--file"
                id="img-file"
                type="file"
                accept="image/jpeg,image/png,image/webp,image/gif,image/avif"
              />
              <span class="form-hint form-hint--media-size"
                >Max 10 MB. Recommended optimized image size: 5–10 MB.</span
              >
            </div>
            <div class="form-group">
              <label class="form-label" for="img-alt">Alt Text *</label>
              <input
                class="form-input"
                id="img-alt"
                type="text"
                placeholder="Descriptive alt text for accessibility and SEO"
              />
            </div>
            <button
              type="button"
              id="upload-btn"
              class="btn btn-ghost media-panel__upload-btn">Upload Image</button
            >
            <div id="upload-status" class="media-panel__upload-status"></div>
            <div id="uploaded-images" class="media-panel__uploaded-list"></div>
          </div>
        </div>
      </div>
    </div>
  </form>

  <!-- Draft preview overlay -->
  <div id="draft-preview" class="draft-preview is-hidden" aria-hidden="true">
    <div class="draft-preview__bar">
      <span class="draft-preview__badge">Draft Preview</span>
      <span class="draft-preview__note"
        >Previewing current editor content — unsaved changes are included.</span
      >
      <button type="button" id="preview-close" class="draft-preview__close-btn"
        >← Back to Editor</button
      >
    </div>
    <div class="draft-preview__scroll" id="draft-preview-scroll"></div>
  </div>
</AdminLayout>

<style>
  @import "../../../styles/pages/admin-article-new.css";
  @import "../../../styles/pages/blog-article.css";
</style>

<script>
  let createdArticleId: number | null = null;
  let uploadSessionId: string | null = null;
  let toastTimer: number | undefined;
  const previewMediaItems: Array<{
    url: string;
    alt_text: string;
    resource_type: "image" | "video";
  }> = [];

  const form = document.getElementById("article-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const uploadBtn = document.getElementById("upload-btn") as HTMLButtonElement;
  const uploadStatus = document.getElementById(
    "upload-status",
  ) as HTMLDivElement;
  const uploadedImages = document.getElementById(
    "uploaded-images",
  ) as HTMLDivElement;
  const categorySelect = document.getElementById(
    "category",
  ) as HTMLSelectElement;
  const bodyInput = document.getElementById("body") as HTMLTextAreaElement;
  const editorLocalImageFileInput = document.getElementById(
    "editor-local-image-file",
  ) as HTMLInputElement;
  const textColorInput = document.getElementById(
    "editor-text-color",
  ) as HTMLInputElement;
  const bgColorInput = document.getElementById(
    "editor-bg-color",
  ) as HTMLInputElement;
  const toolbarButtons = Array.from(
    document.querySelectorAll<HTMLButtonElement>("[data-editor-action]"),
  );
  const unorderedListBtn = document.querySelector<HTMLButtonElement>(
    '[data-editor-action="unordered-list"]',
  );
  const orderedListBtn = document.querySelector<HTMLButtonElement>(
    '[data-editor-action="ordered-list"]',
  );
  const undoCheckpointBtn = document.querySelector<HTMLButtonElement>(
    '[data-editor-action="undo-checkpoint"]',
  );
  const undoCheckpoints: string[] = [];
  const redoCheckpoints: string[] = [];
  const MAX_UNDO_CHECKPOINTS = 50;
  const MAX_IMAGE_BYTES = 10 * 1024 * 1024;
  const IMAGE_TOO_LARGE_MESSAGE =
    "Image is too large (max 10 MB). Please optimize it to 5–10 MB before uploading.";

  function focusBodyWithCaret(position: number) {
    bodyInput.focus();
    bodyInput.selectionStart = position;
    bodyInput.selectionEnd = position;
  }

  function getSelectedText(): string {
    const start = bodyInput.selectionStart ?? 0;
    const end = bodyInput.selectionEnd ?? 0;
    return bodyInput.value.slice(start, end);
  }

  function replaceSelection(replacement: string) {
    const start = bodyInput.selectionStart ?? 0;
    const end = bodyInput.selectionEnd ?? 0;
    const currentSelection = bodyInput.value.slice(start, end);
    if (currentSelection === replacement) return;

    saveUndoCheckpoint();
    bodyInput.setRangeText(replacement, start, end, "end");
    focusBodyWithCaret(start + replacement.length);
    updateToolbarState();
  }

  function updateUndoButtonState() {
    if (!undoCheckpointBtn) return;
    undoCheckpointBtn.disabled = undoCheckpoints.length === 0;
  }

  function saveUndoCheckpoint(clearRedo = true) {
    const current = bodyInput.value;
    if (undoCheckpoints[undoCheckpoints.length - 1] === current) {
      return;
    }

    undoCheckpoints.push(current);
    if (undoCheckpoints.length > MAX_UNDO_CHECKPOINTS) {
      undoCheckpoints.shift();
    }

    if (clearRedo) {
      redoCheckpoints.length = 0;
    }

    updateUndoButtonState();
  }

  function undoLastCheckpoint() {
    const previous = undoCheckpoints.pop();
    if (previous == null) return;

    const current = bodyInput.value;
    if (redoCheckpoints[redoCheckpoints.length - 1] !== current) {
      redoCheckpoints.push(current);
      if (redoCheckpoints.length > MAX_UNDO_CHECKPOINTS) {
        redoCheckpoints.shift();
      }
    }

    const nextCaret = Math.min(bodyInput.selectionStart ?? 0, previous.length);
    bodyInput.value = previous;
    focusBodyWithCaret(nextCaret);
    updateUndoButtonState();
    updateToolbarState();
  }

  function redoLastCheckpoint() {
    const next = redoCheckpoints.pop();
    if (next == null) return;

    saveUndoCheckpoint(false);

    const nextCaret = Math.min(bodyInput.selectionStart ?? 0, next.length);
    bodyInput.value = next;
    focusBodyWithCaret(nextCaret);
    updateUndoButtonState();
    updateToolbarState();
  }

  function isCaretInsideList(tag: "ul" | "ol"): boolean {
    const cursor = bodyInput.selectionStart ?? 0;
    const lowerValue = bodyInput.value.toLowerCase();
    const before = lowerValue.slice(0, cursor);
    const after = lowerValue.slice(cursor);

    const openIndex = before.lastIndexOf(`<${tag}>`);
    const closeIndex = before.lastIndexOf(`</${tag}>`);

    return (
      openIndex !== -1 && openIndex > closeIndex && after.includes(`</${tag}>`)
    );
  }

  function updateToolbarState() {
    const inUnorderedList = isCaretInsideList("ul");
    const inOrderedList = isCaretInsideList("ol");

    if (unorderedListBtn) {
      unorderedListBtn.classList.toggle("is-active", inUnorderedList);
      unorderedListBtn.setAttribute(
        "aria-pressed",
        inUnorderedList ? "true" : "false",
      );
    }

    if (orderedListBtn) {
      orderedListBtn.classList.toggle("is-active", inOrderedList);
      orderedListBtn.setAttribute(
        "aria-pressed",
        inOrderedList ? "true" : "false",
      );
    }
  }

  function wrapSelection(prefix: string, suffix: string, fallback: string) {
    const selection = getSelectedText().trim() || fallback;
    replaceSelection(`${prefix}${selection}${suffix}`);
  }

  function clearInlineFormatting() {
    const selection = getSelectedText();
    if (!selection) return;

    const cleaned = selection
      .replace(/<\/?span\b[^>]*>/gi, "")
      .replace(/<\/?(strong|em|u)\b[^>]*>/gi, "")
      .replace(/\sstyle=("|')[\s\S]*?\1/gi, "");

    replaceSelection(cleaned);
  }

  function adjustFontSizeSelection(
    direction: 1 | -1,
    fallbackSizeRem: number,
    fallbackText: string,
  ) {
    const selection = getSelectedText().trim();
    const spanMatch = selection.match(
      /^<span\s+style=("|')([\s\S]*?)\1>([\s\S]*?)<\/span>$/i,
    );

    if (spanMatch) {
      const quote = spanMatch[1];
      const styleValue = spanMatch[2];
      const innerContent = spanMatch[3];
      const fontSizeMatch = styleValue.match(
        /font-size\s*:\s*([0-9]*\.?[0-9]+)\s*(px|rem|em)/i,
      );

      if (fontSizeMatch) {
        const currentSize = Number(fontSizeMatch[1]);
        const unit = fontSizeMatch[2].toLowerCase();
        const step = unit === "px" ? 2 : 0.125;
        const minSize = unit === "px" ? 8 : 0.5;
        const maxSize = unit === "px" ? 72 : 3;
        const nextSize = Math.max(
          minSize,
          Math.min(
            maxSize,
            Number((currentSize + step * direction).toFixed(3)),
          ),
        );
        const formattedSize =
          unit === "px" ? String(Math.round(nextSize)) : String(nextSize);

        const nextStyle = styleValue.replace(
          /font-size\s*:\s*[0-9]*\.?[0-9]+\s*(px|rem|em)\s*;?/i,
          `font-size: ${formattedSize}${unit};`,
        );

        replaceSelection(
          `<span style=${quote}${nextStyle}${quote}>${innerContent}</span>`,
        );
        return;
      }
    }

    wrapSelection(
      `<span style=\"font-size: ${fallbackSizeRem}rem;\">`,
      "</span>",
      fallbackText,
    );
  }

  function insertList(type: "unordered-list" | "ordered-list") {
    const selection = getSelectedText().trim();

    const selectedListMatch = selection.match(
      /^<(ul|ol)>\s*([\s\S]*?)\s*<\/\1>$/i,
    );
    if (selectedListMatch) {
      const sourceTag = selectedListMatch[1].toLowerCase();
      const sourceType = sourceTag === "ol" ? "ordered-list" : "unordered-list";
      const listBody = selectedListMatch[2];
      const items = Array.from(listBody.matchAll(/<li>([\s\S]*?)<\/li>/gi))
        .map((match) => (match[1] ?? "").trim())
        .filter((item) => item.length > 0);

      if (items.length) {
        if (sourceType === type) {
          replaceSelection(items.join("\n"));
        } else {
          const openTag = type === "ordered-list" ? "<ol>" : "<ul>";
          const closeTag = type === "ordered-list" ? "</ol>" : "</ul>";
          const switchedMarkup = `${openTag}\n${items.map((item) => `  <li>${item}</li>`).join("\n")}\n${closeTag}`;
          replaceSelection(switchedMarkup);
        }
        return;
      }
    }

    const items = (selection || "List item")
      .split(/\r?\n/)
      .map((item) => item.trim())
      .filter((item) => item.length > 0);

    const openTag = type === "ordered-list" ? "<ol>" : "<ul>";
    const closeTag = type === "ordered-list" ? "</ol>" : "</ul>";
    const listMarkup = `${openTag}\n${items.map((item) => `  <li>${item}</li>`).join("\n")}\n${closeTag}`;

    replaceSelection(listMarkup);
  }

  function continueListOnEnter(event: KeyboardEvent) {
    if (
      event.key !== "Enter" ||
      event.shiftKey ||
      event.ctrlKey ||
      event.altKey ||
      event.metaKey ||
      event.isComposing
    ) {
      return;
    }

    const selectionStart = bodyInput.selectionStart ?? 0;
    const selectionEnd = bodyInput.selectionEnd ?? 0;
    if (selectionStart !== selectionEnd) return;

    const value = bodyInput.value;
    const lineStart = value.lastIndexOf("\n", selectionStart - 1) + 1;
    const nextLineBreak = value.indexOf("\n", selectionStart);
    const lineEnd = nextLineBreak === -1 ? value.length : nextLineBreak;
    const currentLine = value.slice(lineStart, lineEnd);

    const listItemMatch = currentLine.match(/^(\s*)<li>(.*)<\/li>\s*$/);
    if (!listItemMatch) return;

    event.preventDefault();

    const indent = listItemMatch[1] ?? "";
    const content = (listItemMatch[2] ?? "").trim();

    if (!content) {
      saveUndoCheckpoint();

      const removeEnd =
        lineEnd < value.length && value[lineEnd] === "\n"
          ? lineEnd + 1
          : lineEnd;
      bodyInput.setRangeText("", lineStart, removeEnd, "start");

      const updatedValue = bodyInput.value;
      const tail = updatedValue.slice(lineStart);
      const closeMatch = tail.match(/^\s*<\/(ul|ol)>\s*$/m);

      if (!closeMatch || closeMatch.index == null) {
        focusBodyWithCaret(lineStart);
        return;
      }

      const closeLineStart = lineStart + closeMatch.index;
      const closeLineEnd = updatedValue.indexOf("\n", closeLineStart);

      if (closeLineEnd === -1) {
        bodyInput.setRangeText(
          "\n",
          updatedValue.length,
          updatedValue.length,
          "end",
        );
        focusBodyWithCaret(updatedValue.length + 1);
        return;
      }

      focusBodyWithCaret(closeLineEnd + 1);
      return;
    }

    saveUndoCheckpoint();

    const insertText = `\n${indent}<li></li>`;
    bodyInput.setRangeText(insertText, lineEnd, lineEnd, "end");

    const caretPosition = lineEnd + 1 + indent.length + 4;
    focusBodyWithCaret(caretPosition);
  }

  function indentCurrentListItem(outdent: boolean): boolean {
    const selectionStart = bodyInput.selectionStart ?? 0;
    const selectionEnd = bodyInput.selectionEnd ?? 0;
    if (selectionStart !== selectionEnd) return false;

    const value = bodyInput.value;
    const lineStart = value.lastIndexOf("\n", selectionStart - 1) + 1;
    const nextLineBreak = value.indexOf("\n", selectionStart);
    const lineEnd = nextLineBreak === -1 ? value.length : nextLineBreak;
    const currentLine = value.slice(lineStart, lineEnd);
    const listItemMatch = currentLine.match(/^(\s*)<li>(.*)<\/li>\s*$/);
    if (!listItemMatch) return false;

    const currentIndent = listItemMatch[1] ?? "";
    const content = listItemMatch[2] ?? "";
    const nextIndent = outdent
      ? currentIndent.replace(/^ {1,2}/, "")
      : `${currentIndent}  `;

    if (outdent && currentIndent === nextIndent) return true;

    saveUndoCheckpoint();

    const updatedLine = `${nextIndent}<li>${content}</li>`;
    bodyInput.setRangeText(updatedLine, lineStart, lineEnd, "start");

    const delta = nextIndent.length - currentIndent.length;
    const caretOffset = Math.max(0, selectionStart - lineStart + delta);
    focusBodyWithCaret(lineStart + caretOffset);
    return true;
  }

  function convertPlainListPaste(text: string): string | null {
    const lines = text.split(/\r?\n/);
    const meaningful = lines.map((line) => line.trim()).filter(Boolean);
    if (meaningful.length === 0) return null;

    const bulletPattern = /^[-*]\s+(.+)$/;
    const orderedPattern = /^\d+\.\s+(.+)$/;

    const allBulleted = meaningful.every((line) => bulletPattern.test(line));
    const allOrdered = meaningful.every((line) => orderedPattern.test(line));
    if (!allBulleted && !allOrdered) return null;

    const itemPattern = allOrdered ? orderedPattern : bulletPattern;
    const items = meaningful
      .map((line) => line.match(itemPattern)?.[1]?.trim() ?? "")
      .filter((item) => item.length > 0);
    if (!items.length) return null;

    const openTag = allOrdered ? "<ol>" : "<ul>";
    const closeTag = allOrdered ? "</ol>" : "</ul>";
    return `${openTag}\n${items.map((item) => `  <li>${item}</li>`).join("\n")}\n${closeTag}`;
  }

  function normalizeListMarkup(value: string): string {
    let normalized = value.replace(
      /^[ \t]*<li>[ \t]*<\/li>[ \t]*(\r?\n)?/gm,
      "",
    );

    let changed = true;
    while (changed) {
      const next = normalized
        .replace(/<ul>\s*<\/ul>/g, "")
        .replace(/<ol>\s*<\/ol>/g, "");
      changed = next !== normalized;
      normalized = next;
    }

    return normalized;
  }

  function handleEditorKeydown(event: KeyboardEvent) {
    if ((event.ctrlKey || event.metaKey) && !event.altKey) {
      const key = event.key.toLowerCase();

      if (key === "z" && event.shiftKey) {
        event.preventDefault();
        redoLastCheckpoint();
        return;
      }

      if (key === "z" && !event.shiftKey) {
        event.preventDefault();
        undoLastCheckpoint();
        return;
      }

      if (key === "y") {
        event.preventDefault();
        redoLastCheckpoint();
        return;
      }
    }

    if (event.key === "Tab") {
      if (indentCurrentListItem(event.shiftKey)) {
        event.preventDefault();
      }
      return;
    }

    continueListOnEnter(event);
  }

  function handleEditorPaste(event: ClipboardEvent) {
    const pastedText = event.clipboardData?.getData("text/plain");
    if (!pastedText) return;

    const converted = convertPlainListPaste(pastedText);
    if (!converted) return;

    event.preventDefault();
    replaceSelection(converted);
  }

  function pickLocalEditorImageFile(): Promise<File | null> {
    return new Promise((resolve) => {
      editorLocalImageFileInput.value = "";

      const handleChange = () => {
        const file = editorLocalImageFileInput.files?.[0] ?? null;
        editorLocalImageFileInput.removeEventListener("change", handleChange);
        resolve(file);
      };

      editorLocalImageFileInput.addEventListener("change", handleChange, {
        once: true,
      });
      editorLocalImageFileInput.click();
    });
  }

  async function uploadLocalEditorImage(
    file: File,
    altText: string,
  ): Promise<string | null> {
    if (!validateImageUploadSize(file)) return null;

    let sessionId = uploadSessionId;

    if (!createdArticleId && !sessionId) {
      sessionId = await createUploadSession();
      if (!sessionId) return null;
      uploadSessionId = sessionId;
    }

    try {
      const dataUri = await new Promise<string>((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => resolve(reader.result as string);
        reader.onerror = reject;
        reader.readAsDataURL(file);
      });

      const res = await fetch("/api/upload", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          file_data: dataUri,
          mime_type: file.type,
          file_size: file.size,
          ...(createdArticleId
            ? { article_id: String(createdArticleId) }
            : { upload_session_id: sessionId }),
          alt_text: altText,
        }),
      });

      const data = await res.json();
      if (!res.ok) {
        showToast(data.error ?? "Local image upload failed.", "error");
        return null;
      }

      return String(data.media_url ?? data.image_url ?? "");
    } catch {
      showToast("Network error during local image upload.", "error");
      return null;
    }
  }

  function appendUploadedMediaItem(
    name: string,
    mediaId?: number,
    url?: string,
  ) {
    const safeName = name.replace(/</g, "&lt;").replace(/>/g, "&gt;");
    const safeUrl = (url ?? "").replace(/"/g, "&quot;");
    const idLabel = Number.isFinite(mediaId) ? `#${mediaId}` : "#staged";

    let html = `<div class="media-upload-item">
      <span class="media-upload-item__id">${idLabel}</span>`;

    if (safeUrl) {
      html += `<a href="${safeUrl}" target="_blank" class="media-upload-item__link">${safeName}</a>`;
    } else {
      html += `<span class="media-upload-item__link">${safeName}</span>`;
    }

    html += `</div>`;

    uploadedImages.insertAdjacentHTML("beforeend", html);
  }

  async function createUploadSession(): Promise<string | null> {
    try {
      const res = await fetch("/api/admin/uploads/sessions", {
        method: "POST",
      });

      if (res.status === 401) {
        window.location.href = "/admin";
        return null;
      }

      const data = await res.json();
      if (!res.ok) {
        showToast(data.error ?? "Could not start upload session.", "error");
        return null;
      }

      return String(data.upload_session_id ?? "").trim() || null;
    } catch {
      showToast("Network error while starting upload session.", "error");
      return null;
    }
  }

  async function insertImage(kind: "image-inline" | "image-block") {
    const result = await (window as any).showEditorDialog({
      title:
        kind === "image-inline" ? "Insert Inline Image" : "Insert Image Block",
      fields: [
        {
          id: "source",
          label: "Image Source",
          type: "select",
          default: "url",
          options: [
            { value: "url", label: "Use URL" },
            { value: "upload", label: "Upload Local Image" },
          ],
        },
        {
          id: "url",
          label: "Image URL",
          type: "url",
          placeholder: "https://",
          default: "https://",
        },
        {
          id: "alt",
          label: "Alt Text",
          type: "text",
          placeholder: "Descriptive alt text",
          default: "",
        },
      ],
    });

    if (!result) return;
    const source = result.source === "upload" ? "upload" : "url";
    const altText = result.alt || "Image";

    let imageUrl = "";

    if (source === "upload") {
      const file = await pickLocalEditorImageFile();
      if (!file) return;
      const uploadedUrl = await uploadLocalEditorImage(file, altText);
      if (!uploadedUrl) return;
      imageUrl = uploadedUrl;
    } else {
      imageUrl = String(result.url ?? "").trim();
      if (!imageUrl) return;
    }

    let markup = "";
    if (kind === "image-inline") {
      markup = `<img src="${imageUrl}" alt="${altText}" style="max-width: 100%; height: auto; vertical-align: middle;" />`;
    } else {
      markup = `<figure>\n  <img src="${imageUrl}" alt="${altText}" style="max-width: 100%; height: auto;" />\n  <figcaption>${altText}</figcaption>\n</figure>`;
    }

    replaceSelection(markup);
  }

  async function insertLink() {
    const selected = getSelectedText().trim();
    const result = await (window as any).showEditorDialog({
      title: "Insert Link",
      fields: [
        {
          id: "href",
          label: "URL",
          type: "url",
          placeholder: "https://",
          default: "https://",
        },
        {
          id: "label",
          label: "Link Text",
          type: "text",
          placeholder: "Link text",
          default: selected || "Link text",
        },
      ],
    });
    if (!result || !result.href) return;
    replaceSelection(`<a href="${result.href}">${result.label || "Link"}</a>`);
  }

  function insertQuote() {
    const selection = getSelectedText().trim();
    const quoteText = selection || "Quote text";
    replaceSelection(`<blockquote>${quoteText}</blockquote>`);
  }

  async function insertHeading() {
    const selected = getSelectedText().trim();
    const result = await (window as any).showEditorDialog({
      title: "Insert Heading",
      fields: [
        {
          id: "text",
          label: "Heading Text",
          type: "text",
          placeholder: "Section heading",
          default: selected || "",
        },
        {
          id: "level",
          label: "Heading Level",
          type: "select",
          default: "2",
          options: [
            { value: "1", label: "H1 — Page Title" },
            { value: "2", label: "H2 — Section" },
            { value: "3", label: "H3 — Sub-Section" },
            { value: "4", label: "H4 — Detail" },
            { value: "5", label: "H5 — Minor" },
            { value: "6", label: "H6 — Smallest" },
          ],
        },
      ],
    });
    if (!result || !result.text) return;
    const level = Math.min(6, Math.max(1, Number(result.level) || 2));
    replaceSelection(`<h${level}>${result.text}</h${level}>`);
  }

  async function handleEditorAction(action: string) {
    if (action === "bold") {
      wrapSelection("<strong>", "</strong>", "Bold text");
      return;
    }
    if (action === "italic") {
      wrapSelection("<em>", "</em>", "Italic text");
      return;
    }
    if (action === "underline") {
      wrapSelection("<u>", "</u>", "Underlined text");
      return;
    }
    if (action === "link") {
      await insertLink();
      return;
    }
    if (action === "quote") {
      insertQuote();
      return;
    }
    if (action === "heading") {
      await insertHeading();
      return;
    }
    if (action === "color") {
      const selectedColor = textColorInput.value || "#6f89ff";
      wrapSelection(
        `<span style=\"color: ${selectedColor};\">`,
        "</span>",
        "Colored text",
      );
      return;
    }
    if (action === "background-color") {
      const selectedBackground = bgColorInput.value || "#f8e040";
      wrapSelection(
        `<span style=\"background-color: ${selectedBackground};\">`,
        "</span>",
        "Highlighted text",
      );
      return;
    }
    if (action === "undo-checkpoint") {
      undoLastCheckpoint();
      return;
    }
    if (action === "font-size-increase") {
      adjustFontSizeSelection(1, 1.125, "Larger text");
      return;
    }
    if (action === "font-size-decrease") {
      adjustFontSizeSelection(-1, 0.875, "Smaller text");
      return;
    }
    if (action === "clear-inline") {
      clearInlineFormatting();
      return;
    }
    if (action === "unordered-list" || action === "ordered-list") {
      insertList(action);
      return;
    }
    if (action === "image-inline" || action === "image-block") {
      await insertImage(action as "image-inline" | "image-block");
    }
  }

  toolbarButtons.forEach((button) => {
    button.addEventListener("click", async () => {
      const action = button.dataset.editorAction;
      if (!action) return;
      await handleEditorAction(action);
      updateToolbarState();
    });
  });

  bodyInput.addEventListener("keydown", handleEditorKeydown);
  bodyInput.addEventListener("paste", handleEditorPaste);
  bodyInput.addEventListener("input", updateToolbarState);
  bodyInput.addEventListener("click", updateToolbarState);
  bodyInput.addEventListener("keyup", updateToolbarState);
  bodyInput.addEventListener("focus", updateToolbarState);

  updateUndoButtonState();
  updateToolbarState();

  function ensureToastStack(): HTMLDivElement {
    let stack = document.getElementById("toast-stack") as HTMLDivElement | null;
    if (!stack) {
      stack = document.createElement("div");
      stack.id = "toast-stack";
      stack.className = "toast-stack";
      document.body.appendChild(stack);
    }

    return stack;
  }

  function showToast(message: string, type: "error" | "success") {
    const stack = ensureToastStack();
    stack.innerHTML = `<div class="toast toast--${type}">${message}</div>`;
    stack.classList.add("is-visible");

    if (toastTimer) window.clearTimeout(toastTimer);
    toastTimer = window.setTimeout(() => {
      stack.classList.remove("is-visible");
    }, 2600);
  }

  function validateImageUploadSize(file: File): boolean {
    if (!file.type.startsWith("image/")) return true;
    if (file.size <= MAX_IMAGE_BYTES) return true;

    showToast(IMAGE_TOO_LARGE_MESSAGE, "error");
    return false;
  }

  async function loadCategories() {
    try {
      const res = await fetch("/api/categories");
      if (!res.ok) return;

      const data = await res.json();
      const categories = Array.isArray(data.categories) ? data.categories : [];

      categorySelect.innerHTML = `<option value="">Uncategorized</option>`;

      for (const category of categories) {
        categorySelect.insertAdjacentHTML(
          "beforeend",
          `<option value="${category.id}">${category.name}</option>`,
        );
      }
    } catch {
      // Keep the editor functional even if category lookup fails.
    }
  }

  // Auto-generate slug from title
  const titleInput = document.getElementById("title") as HTMLInputElement;
  const slugInput = document.getElementById("slug") as HTMLInputElement;

  titleInput.addEventListener("input", () => {
    if (!slugInput.dataset.userEdited) {
      slugInput.value = titleInput.value
        .toLowerCase()
        .trim()
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/^-|-$/g, "");
    }
  });

  slugInput.addEventListener("input", () => {
    slugInput.dataset.userEdited = "1";
  });

  // Submit
  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    bodyInput.value = normalizeListMarkup(bodyInput.value);

    const title = titleInput.value.trim();
    const slug = slugInput.value.trim() || undefined;
    const body = (
      document.getElementById("body") as HTMLTextAreaElement
    ).value.trim();
    const description =
      (
        document.getElementById("description") as HTMLTextAreaElement
      ).value.trim() || undefined;
    const statusVal = (document.getElementById("status") as HTMLSelectElement)
      .value;
    const categoryValue = categorySelect.value;
    const tagsRaw = (document.getElementById("tags") as HTMLInputElement).value;
    const tags = tagsRaw
      .split(",")
      .map((t) => t.trim())
      .filter(Boolean);

    if (!title || !body) {
      showToast("Title and body are required.", "error");
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = "Saving…";

    try {
      const payload: Record<string, unknown> = {
        title,
        body,
        status: statusVal,
      };
      if (slug) payload.slug = slug;
      if (description) payload.description = description;
      if (tags.length) payload.tags = tags;
      if (categoryValue) payload.category_id = Number(categoryValue);
      if (uploadSessionId) payload.upload_session_id = uploadSessionId;

      const res = await fetch("/api/articles", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(payload),
      });

      if (res.status === 401) {
        window.location.href = "/admin";
        return;
      }

      const data = await res.json();

      if (!res.ok) {
        showToast(data.error ?? "Failed to create article.", "error");
        return;
      }

      // Redirect to the edit page — it has full update + image upload support
      window.location.href = `/admin/articles/${data.slug}`;
    } catch {
      showToast("Network error. Please try again.", "error");
    } finally {
      submitBtn.disabled = false;
      if (submitBtn.textContent === "Saving…") {
        submitBtn.textContent = "Create Article";
      }
    }
  });

  // Image upload
  uploadBtn.addEventListener("click", async () => {
    const fileInput = document.getElementById("img-file") as HTMLInputElement;
    const altInput = document.getElementById("img-alt") as HTMLInputElement;
    const file = fileInput.files?.[0];
    const alt = altInput.value.trim();

    if (!file) {
      showToast("Select an image file.", "error");
      return;
    }
    if (!validateImageUploadSize(file)) {
      return;
    }
    if (!alt) {
      showToast("Alt text is required.", "error");
      return;
    }

    uploadBtn.disabled = true;
    uploadStatus.textContent = "Uploading…";

    try {
      const uploadedUrl = await uploadLocalEditorImage(file, alt);
      if (!uploadedUrl) {
        showToast("Upload failed.", "error");
        return;
      }

      uploadStatus.textContent = "";
      showToast("Image uploaded successfully.", "success");
      previewMediaItems.push({
        url: uploadedUrl,
        alt_text: alt,
        resource_type: "image",
      });
      appendUploadedMediaItem(file.name, undefined, uploadedUrl);
      fileInput.value = "";
      altInput.value = "";
    } catch {
      showToast("Network error during upload.", "error");
    } finally {
      uploadBtn.disabled = false;
    }
  });

  // ─── Draft Preview ───
  const previewBtn = document.getElementById(
    "preview-btn",
  ) as HTMLButtonElement;
  const draftPreview = document.getElementById(
    "draft-preview",
  ) as HTMLDivElement;
  const previewScroll = document.getElementById(
    "draft-preview-scroll",
  ) as HTMLDivElement;
  const previewCloseBtn = document.getElementById(
    "preview-close",
  ) as HTMLButtonElement;

  function escapeHtml(str: string): string {
    return String(str)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;");
  }

  function escapeAttr(str: string): string {
    return String(str).replace(/"/g, "&quot;");
  }

  function previewBodyToHtml(text: string): string {
    const blockTagPattern =
      /^\s*<(ul|ol|li|figure|img|h1|h2|h3|h4|h5|h6|blockquote|pre|table|hr|p|div|section|article)\b/i;
    return text
      .split(/\n{2,}/)
      .map((para) => para.trim())
      .filter(Boolean)
      .map((para) =>
        blockTagPattern.test(para)
          ? para
          : `<p>${para.replace(/\n/g, "<br>")}</p>`,
      )
      .join("\n");
  }

  function buildPreviewHtml(
    title: string,
    description: string,
    body: string,
    media: typeof previewMediaItems,
  ): string {
    const bodyHtml = previewBodyToHtml(body);
    const heroMedia = media[0] ?? null;
    const inlineMedia = media.slice(1);
    const today = new Date().toLocaleDateString("en-US", {
      month: "long",
      day: "numeric",
      year: "numeric",
    });

    let html = `<article class="article-wrap">`;

    html += `<header class="article-header page-wrap"><div class="content-col">`;
    html += `<h1 class="article-title">${escapeHtml(title || "(Untitled)")}</h1>`;
    if (description) {
      html += `<p class="article-lede">${escapeHtml(description)}</p>`;
    }
    html += `<div class="article-byline"><time class="article-byline__date">${today}</time></div>`;
    html += `</div></header>`;

    if (heroMedia) {
      html += `<div class="hero-image-wrap page-wrap"><div class="content-col"><figure class="hero-image">`;
      if (heroMedia.resource_type === "video") {
        html += `<video controls preload="metadata" src="${escapeAttr(heroMedia.url)}"></video>`;
      } else {
        html += `<img src="${escapeAttr(heroMedia.url)}" alt="${escapeAttr(heroMedia.alt_text)}" />`;
      }
      if (heroMedia.alt_text) {
        html += `<figcaption class="hero-image__caption">${escapeHtml(heroMedia.alt_text)}</figcaption>`;
      }
      html += `</figure></div></div>`;
    }

    html += `<div class="rule-wrap page-wrap" aria-hidden="true"><div class="content-col"><div class="rule-inner"><span class="rule-line"></span><span class="rule-glyph">✦</span><span class="rule-line"></span></div></div></div>`;
    html += `<div class="article-body page-wrap"><div class="content-col"><div class="prose">${bodyHtml}</div></div></div>`;

    if (inlineMedia.length > 0) {
      html += `<div class="article-images page-wrap"><div class="content-col"><div class="image-grid">`;
      for (const m of inlineMedia) {
        html += `<figure class="image-grid__item">`;
        if (m.resource_type === "video") {
          html += `<video controls preload="metadata" src="${escapeAttr(m.url)}"></video>`;
        } else {
          html += `<img src="${escapeAttr(m.url)}" alt="${escapeAttr(m.alt_text)}" loading="lazy" />`;
        }
        html += `<figcaption>${escapeHtml(m.alt_text)}</figcaption></figure>`;
      }
      html += `</div></div></div>`;
    }

    html += `</article>`;
    return html;
  }

  function openPreview() {
    const title = (
      document.getElementById("title") as HTMLInputElement
    ).value.trim();
    const description = (
      document.getElementById("description") as HTMLTextAreaElement
    ).value.trim();
    const body = bodyInput.value.trim();
    const html = buildPreviewHtml(title, description, body, previewMediaItems);
    previewScroll.innerHTML = html;
    previewScroll.scrollTop = 0;
    draftPreview.classList.remove("is-hidden");
    draftPreview.setAttribute("aria-hidden", "false");
    document.body.classList.add("preview-open");
    previewCloseBtn.focus();
  }

  function closePreview() {
    draftPreview.classList.add("is-hidden");
    draftPreview.setAttribute("aria-hidden", "true");
    document.body.classList.remove("preview-open");
    previewBtn.focus();
  }

  previewBtn.addEventListener("click", openPreview);
  previewCloseBtn.addEventListener("click", closePreview);
  document.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.key === "Escape" && !draftPreview.classList.contains("is-hidden")) {
      closePreview();
    }
  });

  loadCategories();
</script>
