---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import AdminMediaGallery from "../../../components/admin/AdminMediaGallery";
const { slug } = Astro.params;
const cloudName = import.meta.env.CLOUDINARY_CLOUD_NAME;
---

<AdminLayout title={`Edit — ${slug}`}>
  <div class="page-header">
    <div>
      <p class="page-header__eyebrow">Articles</p>
      <h1 class="page-header__title">Edit <em>Article</em></h1>
    </div>
    <div class="flex article-actions-head">
      <a href="/admin/dashboard" class="btn btn-ghost">← Back</a>
      <button type="button" id="preview-btn" class="btn btn-ghost"
        >Preview Draft</button
      >
      <button id="delete-btn" class="btn btn-danger">Delete</button>
    </div>
  </div>

  <!-- Loading state -->
  <div id="state-loading" class="state-caption">
    <span class="state-caption__label">Loading Article…</span>
  </div>

  <!-- Error state -->
  <div id="state-error" class="alert alert--error is-hidden"></div>

  <!-- Form (hidden until article data loaded) -->
  <form id="article-form" class="is-hidden" novalidate>
    <div class="editor-grid">
      <!-- Left: content panel -->
      <div>
        <div class="card card--accent-top">
          <p class="panel-heading">Content</p>

          <div class="form-group">
            <label class="form-label" for="title">Title *</label>
            <input
              class="form-input"
              id="title"
              name="title"
              type="text"
              required
            />
          </div>

          <div class="form-group">
            <label class="form-label" for="slug-field">Slug</label>
            <input class="form-input" id="slug-field" name="slug" type="text" />
          </div>

          <div class="form-group form-group--compact">
            <label class="form-label" id="body-editor-label">Body *</label>
            <div id="editor-toolbar"></div>
            <div
              id="body-editor"
              class="form-textarea form-textarea--body quill-editor"
              aria-labelledby="body-editor-label"
              style="background: white; border: 1px solid var(--surface-3); border-radius: 4px; min-height: 400px;"
            >
            </div>
            <!-- Hidden field for form submission -->
            <input type="hidden" id="body" name="body" />
            <input
              type="hidden"
              id="article-slug"
              name="article-slug"
              value={slug}
            />
            <span class="form-hint">Visual editor. Format text directly.</span>
          </div>
        </div>
      </div>

      <!-- Right: meta panels -->
      <div class="meta-stack">
        <!-- Status panel -->
        <div class="card card--accent-top">
          <p class="panel-heading">Publish</p>

          <div class="form-group">
            <label class="form-label" for="status">Status</label>
            <select class="form-select" id="status" name="status">
              <option value="draft">Draft</option>
              <option value="published">Published</option>
            </select>
          </div>

          <div class="form-group">
            <label class="form-label" for="category">Category</label>
            <select class="form-select" id="category" name="category">
              <option value="">Uncategorized</option>
            </select>
          </div>

          <div class="form-group form-group--buttons">
            <button class="btn-cta" type="submit" id="submit-btn">
              Save Changes
            </button>
          </div>
        </div>

        <!-- SEO panel -->
        <div class="card card--kirby-top">
          <p class="panel-heading">SEO Fields</p>

          <div class="form-group">
            <label class="form-label" for="description">Meta Description</label>
            <textarea
              class="form-textarea form-textarea--meta"
              id="description"
              name="description"
              placeholder="Brief description for search engines…"></textarea>
            <span class="form-hint">Recommended: 120–160 characters</span>
          </div>

          <div class="form-group form-group--compact">
            <label class="form-label" for="tags">Tags / Labels</label>
            <input
              class="form-input"
              id="tags"
              name="tags"
              type="text"
              placeholder="keyword, topic, label"
            />
            <span class="form-hint">Comma-separated</span>
          </div>
        </div>

        <!-- Media panel -->
        <div class="card" id="media-gallery-wrapper">
          <p class="panel-heading">Media</p>
          <AdminMediaGallery
            client:load
            cloudName={cloudName}
            galleryId="article-edit-media"
            emptyMessage="No media uploaded yet."
          />
          <div class="form-group form-group--spaced-top">
            <label class="form-label" for="img-file">Add Image or Video</label>
            <input
              class="form-input form-input--file"
              id="img-file"
              name="media-file"
              type="file"
              accept="image/jpeg,image/png,image/webp,image/gif,image/avif,video/mp4,video/webm,video/ogg,video/quicktime"
            />
            <span class="form-hint form-hint--media-size"
              >Images: max 10 MB. Videos: max 200 MB.</span
            >
          </div>
          <div class="form-group">
            <label class="form-label" for="img-alt">Alt Text / Caption *</label>
            <input
              class="form-input"
              id="img-alt"
              name="media-alt"
              type="text"
              placeholder="Descriptive alt text or short caption"
            />
          </div>
          <button
            type="button"
            id="upload-btn"
            class="btn btn-ghost media-panel__upload-btn">Upload Media</button
          >
          <div id="upload-status" class="media-panel__upload-status"></div>
        </div>

        <!-- Danger Zone panel -->
        <div class="card card--danger-top danger-zone">
          <p class="panel-heading panel-heading--danger">Danger Zone</p>
          <p class="danger-zone__note">
            Permanently delete this article and all associated media records.
          </p>
          <button
            type="button"
            id="delete-btn-panel"
            class="btn btn-danger danger-zone__delete-btn"
            >Delete Article</button
          >
        </div>
      </div>
    </div>
  </form>

  <!-- Draft preview overlay -->
  <div id="draft-preview" class="draft-preview is-hidden" aria-hidden="true">
    <div class="draft-preview__bar">
      <span class="draft-preview__badge">Draft Preview</span>
      <span class="draft-preview__note"
        >Previewing current editor content — unsaved changes are included.</span
      >
      <button type="button" id="preview-close" class="draft-preview__close-btn"
        >← Back to Editor</button
      >
    </div>
    <div class="draft-preview__scroll" id="draft-preview-scroll"></div>
  </div>
</AdminLayout>

<style>
  @import "../../../styles/pages/admin-article-edit.css";
  @import "../../../styles/pages/blog-article.css";

  :global(.ql-toolbar) {
    border: 1px solid var(--surface-3);
    border-radius: 4px 4px 0 0;
    background: var(--surface-1);
  }

  :global(.ql-container) {
    border: 1px solid var(--surface-3);
    border-top: none;
    border-radius: 0 0 4px 4px;
    font-family: inherit;
    font-size: 1rem;
  }

  :global(.ql-editor) {
    min-height: 400px;
    padding: 12px;
  }

  :global(.ql-editor.ql-blank::before) {
    color: var(--surface-3);
    font-style: italic;
  }

  /* Color + background picker swatches */
  :global(.ql-snow .ql-picker.ql-color .ql-picker-options),
  :global(.ql-snow .ql-picker.ql-background .ql-picker-options) {
    width: 184px;
    padding: 4px 2px;
  }

  :global(.ql-snow .ql-color-picker .ql-picker-item) {
    width: 18px;
    height: 18px;
    border-radius: 2px;
  }

  :global(.ql-snow .ql-custom-color-row) {
    clear: both;
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 6px 2px 2px;
    padding-top: 6px;
    border-top: 1px solid rgba(0, 0, 0, 0.12);
  }

  :global(.ql-snow .ql-custom-color-label) {
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #666;
    font-family: "Fira Code", monospace;
    cursor: pointer;
  }

  :global(.ql-snow .ql-custom-color-input) {
    width: 20px;
    height: 20px;
    border: 1px solid #bbb;
    border-radius: 999px;
    background: transparent;
    padding: 0;
    cursor: pointer;
  }

  :global(.ql-snow .ql-custom-color-input::-webkit-color-swatch-wrapper) {
    padding: 0;
    border-radius: 999px;
  }

  :global(.ql-snow .ql-custom-color-input::-webkit-color-swatch) {
    border: none;
    border-radius: 999px;
  }

  :global(.ql-snow .ql-custom-color-clear) {
    border: 1px solid #ccc;
    background: #fff;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 3px 5px;
    cursor: pointer;
    line-height: 1;
    color: #555;
  }

  :global(html[data-theme="dark"]) {
    --quill-toolbar-icon: #ccc;
    --quill-toolbar-icon-active: #4da3ff;
  }

  :global(html[data-theme="light"]) {
    --quill-toolbar-icon: #1c1008;
    --quill-toolbar-icon-active: #1c4268;
  }

  /* Toolbar icon color adapts to active theme */
  :global(.ql-toolbar.ql-snow .ql-stroke) {
    stroke: var(--quill-toolbar-icon) !important;
  }

  :global(.ql-toolbar.ql-snow .ql-fill) {
    fill: var(--quill-toolbar-icon) !important;
  }

  :global(.ql-toolbar.ql-snow button:hover .ql-stroke),
  :global(.ql-toolbar.ql-snow button:focus .ql-stroke),
  :global(.ql-toolbar.ql-snow button.ql-active .ql-stroke),
  :global(.ql-toolbar.ql-snow .ql-picker-label:hover .ql-stroke),
  :global(.ql-toolbar.ql-snow .ql-picker-label.ql-active .ql-stroke),
  :global(.ql-toolbar.ql-snow .ql-picker-item:hover .ql-stroke),
  :global(.ql-toolbar.ql-snow .ql-picker-item.ql-selected .ql-stroke) {
    stroke: var(--quill-toolbar-icon-active) !important;
  }

  :global(.ql-toolbar.ql-snow button:hover .ql-fill),
  :global(.ql-toolbar.ql-snow button:focus .ql-fill),
  :global(.ql-toolbar.ql-snow button.ql-active .ql-fill),
  :global(.ql-toolbar.ql-snow .ql-picker-label:hover .ql-fill),
  :global(.ql-toolbar.ql-snow .ql-picker-label.ql-active .ql-fill),
  :global(.ql-toolbar.ql-snow .ql-picker-item:hover .ql-fill),
  :global(.ql-toolbar.ql-snow .ql-picker-item.ql-selected .ql-fill) {
    fill: var(--quill-toolbar-icon-active) !important;
  }

  /* Resize plugin controls need explicit styles to render visible handles. */
  :global(.ql-resize-overlay) {
    position: absolute;
    box-sizing: border-box;
    border: 1px dashed #444;
    pointer-events: none;
  }

  :global(.ql-resize-handle) {
    position: absolute;
    width: 12px;
    height: 12px;
    background: #fff;
    border: 1px solid #777;
    box-sizing: border-box;
    opacity: 0.85;
    pointer-events: all;
    z-index: 6;
  }

  :global(.ql-resize-handle.tl) {
    top: -6px;
    left: -6px;
    cursor: nwse-resize;
  }

  :global(.ql-resize-handle.tr) {
    top: -6px;
    right: -6px;
    cursor: nesw-resize;
  }

  :global(.ql-resize-handle.br) {
    right: -6px;
    bottom: -6px;
    cursor: nwse-resize;
  }

  :global(.ql-resize-handle.bl) {
    left: -6px;
    bottom: -6px;
    cursor: nesw-resize;
  }

  :global(.ql-resize-toolbar) {
    position: absolute;
    top: -12px;
    right: 0;
    left: 0;
    height: 0;
    min-width: 120px;
    text-align: center;
    color: #333;
    box-sizing: border-box;
    cursor: default;
    pointer-events: all;
    z-index: 7;
  }

  :global(.ql-resize-toolbar button) {
    display: inline-block;
    min-width: 24px;
    height: 24px;
    padding: 2px;
    background: #fff;
    border: 1px solid #999;
    vertical-align: middle;
  }

  :global(.ql-resize-toolbar button:first-child) {
    border-top-left-radius: 3px;
    border-bottom-left-radius: 3px;
  }

  :global(.ql-resize-toolbar button:last-child) {
    border-top-right-radius: 3px;
    border-bottom-right-radius: 3px;
  }

  :global(.ql-resize-toolbar button:not(:first-child)) {
    border-left: none;
  }

  :global(.ql-resize-toolbar button.active) {
    filter: invert(20%);
  }

  :global(.ql-resize-toolbar svg) {
    width: 18px;
  }

  :global(.ql-resize-display) {
    position: absolute;
    padding: 4px 8px;
    text-align: center;
    background: #fff;
    color: #333;
    border: 1px solid #777;
    box-sizing: border-box;
    opacity: 0.85;
    cursor: default;
    line-height: 1;
    z-index: 7;
  }

  :global(.ql-resize-style-left) {
    float: left;
    margin: 0 1em 1em 0;
  }

  :global(.ql-resize-style-center) {
    display: block;
    margin: auto;
    text-align: center;
  }

  :global(.ql-resize-style-right) {
    float: right;
    margin: 0 0 1em 1em;
  }

  :global(.ql-resize-style-full) {
    width: 100% !important;
  }

  :global(.ql-resize-style-full > *) {
    width: 100%;
  }
</style>

<script>
  import type {
    ApiErrorResponse,
    ArticleData,
    ArticleStatus,
    ArticleTag,
    ArticleUpdatePayload,
    CategoriesResponse,
    MediaDeletedEventDetail,
    MediaRecord,
    MediaToastEventDetail,
    ToastType,
    UploadResponse,
  } from "../../../lib/article-editor.types";
  import { MAX_IMAGE_BYTES, MAX_VIDEO_BYTES } from "../../../lib/media";
  import { enableCustomColorPickers } from "../../../lib/quill-custom-colors";

  type QuillEditor = {
    root: HTMLElement;
    on: (eventName: string, handler: () => void) => void;
    getModule: (name: string) => unknown;
    getSelection: (focus?: boolean) => unknown;
    format: (
      name: "color" | "background",
      value: string | false,
      source?: "user" | "api" | "silent",
    ) => void;
    focus: () => void;
  };

  let quillEditor: QuillEditor | null = null;
  let articleData: ArticleData | null = null;
  let articleId: number | null = null;
  let currentMedia: MediaRecord[] = [];
  let toastTimer: number | undefined;

  // Lazy-load Quill styles
  function loadQuillStyles() {
    const core = document.createElement("link");
    core.rel = "stylesheet";
    core.href = "https://cdn.quilljs.com/1.3.6/quill.core.css";
    const snow = document.createElement("link");
    snow.rel = "stylesheet";
    snow.href = "https://cdn.quilljs.com/1.3.6/quill.snow.css";
    document.head.appendChild(core);
    document.head.appendChild(snow);
  }

  function requireElement<T extends HTMLElement>(id: string): T {
    const element = document.getElementById(id) as T | null;
    if (!element) {
      throw new Error(`Missing required element: #${id}`);
    }
    return element;
  }

  const form = requireElement<HTMLFormElement>("article-form");
  const loading = requireElement<HTMLDivElement>("state-loading");
  const error = requireElement<HTMLDivElement>("state-error");
  const submitBtn = requireElement<HTMLButtonElement>("submit-btn");
  const deleteBtn = requireElement<HTMLButtonElement>("delete-btn");
  const deleteBtnPanel = requireElement<HTMLButtonElement>("delete-btn-panel");
  const previewBtn = requireElement<HTMLButtonElement>("preview-btn");
  const draftPreview = requireElement<HTMLDivElement>("draft-preview");
  const previewScroll = requireElement<HTMLDivElement>("draft-preview-scroll");
  const previewCloseBtn = requireElement<HTMLButtonElement>("preview-close");
  const bodyInput = requireElement<HTMLInputElement>("body");
  const slug = requireElement<HTMLInputElement>("article-slug").value;

  async function loadArticle() {
    try {
      const res = await fetch(`/api/admin/articles/${slug}`);
      if (res.status === 401) {
        window.location.href = "/admin";
        return;
      }
      if (!res.ok) {
        throw new Error("Failed to load article");
      }
      const data = (await res.json()) as ArticleData;
      articleData = data;
      articleId = Number(data.id) || null;
      populateForm(data);
      await initializeEditor(data.body || "");
      syncMediaGallery(data.media ?? data.images ?? []);
      form.classList.remove("is-hidden");
      loading.classList.add("is-hidden");
    } catch (err) {
      error.textContent = `Error: ${err instanceof Error ? err.message : "Unknown error"}`;
      error.classList.remove("is-hidden");
      loading.classList.add("is-hidden");
    }
  }

  function populateForm(article: ArticleData): void {
    requireElement<HTMLInputElement>("title").value = article.title || "";
    requireElement<HTMLInputElement>("slug-field").value = article.slug || "";
    requireElement<HTMLSelectElement>("status").value =
      article.status || "draft";
    requireElement<HTMLTextAreaElement>("description").value =
      article.description || "";
    const tagNames = Array.isArray(article.tags)
      ? article.tags
          .map((tag: ArticleTag) => {
            if (typeof tag === "string") return tag;
            if (tag && typeof tag === "object" && "name" in tag) {
              const name = tag.name;
              return typeof name === "string" ? name : "";
            }
            return "";
          })
          .filter(Boolean)
      : [];
    requireElement<HTMLInputElement>("tags").value = tagNames.join(", ");
    requireElement<HTMLSelectElement>("category").value = article.category_id
      ? String(article.category_id)
      : "";
    bodyInput.value = article.body || "";
  }

  const COMIC_PALETTE = [
    "#080808",
    "#1c1008",
    "#ffffff",
    "#f3e9db",
    "#e04030",
    "#1c4268",
    "#f2c85a",
    "#f8e040",
    "#fffef0",
    "#f4ede0",
    "#34c070",
    "#c09838",
  ];

  async function initializeEditor(initialHtml: string): Promise<void> {
    // Lazy-load Quill only when editor is needed
    const [{ default: Quill }, { default: QuillResize }] = await Promise.all([
      import("quill"),
      import("quill-resize-module"),
    ]);
    loadQuillStyles();

    Quill.register("modules/resize", QuillResize, true);

    quillEditor = new Quill("#body-editor", {
      theme: "snow",
      modules: {
        toolbar: [
          ["bold", "italic", "underline"],
          [{ color: COMIC_PALETTE }, { background: COMIC_PALETTE }],
          ["blockquote", "code-block"],
          [{ header: 2 }, { header: 3 }],
          [{ list: "ordered" }, { list: "bullet" }],
          ["link", "image"],
        ],
        resize: {
          modules: ["Resize", "DisplaySize", "Toolbar", "Keyboard"],
          keyboardSelect: true,
          parchment: {
            image: {
              attribute: ["width"],
              limit: {
                minWidth: 100,
              },
            },
          },
        },
      },
      placeholder: "Write your article content here…",
    });

    // Set initial content
    if (initialHtml && quillEditor) {
      quillEditor.root.innerHTML = initialHtml;
    }

    if (!quillEditor) return;

    const editor = quillEditor;
    enableCustomColorPickers(editor);
    editor.root.setAttribute("aria-label", "Article body");

    // Serialize on change
    editor.on("text-change", () => {
      const html = editor.root.innerHTML;
      bodyInput.value = html === "<p><br></p>" ? "" : html;
    });
  }

  function escapeHtml(str: string): string {
    return String(str)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;");
  }

  function escapeAttr(str: string): string {
    return String(str).replace(/"/g, "&quot;");
  }

  function previewBodyToHtml(text: string): string {
    const blockTagPattern =
      /^\s*<(ul|ol|li|figure|img|h1|h2|h3|h4|h5|h6|blockquote|pre|table|hr|p|div|section|article|blockquote)\b/i;
    return text
      .split(/\n{2,}/)
      .map((para: string) => para.trim())
      .filter(Boolean)
      .map((para: string) =>
        blockTagPattern.test(para)
          ? para
          : `<p>${para.replace(/\n/g, "<br>")}</p>`,
      )
      .join("\n");
  }

  function buildPreviewHtml(
    title: string,
    description: string,
    body: string,
    media: MediaRecord[],
  ): string {
    const bodyHtml = previewBodyToHtml(body);
    const heroMedia = media?.[0] ?? null;
    const inlineMedia = media?.slice(1) ?? [];
    const today = new Date().toLocaleDateString("en-US", {
      month: "long",
      day: "numeric",
      year: "numeric",
    });

    let html = `<article class="article-wrap">`;

    html += `<header class="article-header page-wrap"><div class="content-col">`;
    html += `<h1 class="article-title">${escapeHtml(title || "(Untitled)")}</h1>`;
    if (description) {
      html += `<p class="article-lede">${escapeHtml(description)}</p>`;
    }
    html += `<div class="article-byline"><time class="article-byline__date">${today}</time></div>`;
    html += `</div></header>`;

    if (heroMedia) {
      html += `<div class="hero-image-wrap page-wrap"><div class="content-col"><figure class="hero-image">`;
      if (heroMedia.resource_type === "video") {
        html += `<video controls preload="metadata" src="${escapeAttr(heroMedia.url)}"></video>`;
      } else {
        html += `<img src="${escapeAttr(heroMedia.url)}" alt="${escapeAttr(heroMedia.alt_text)}" />`;
      }
      if (heroMedia.alt_text) {
        html += `<figcaption class="hero-image__caption">${escapeHtml(heroMedia.alt_text)}</figcaption>`;
      }
      html += `</figure></div></div>`;
    }

    html += `<div class="rule-wrap page-wrap" aria-hidden="true"><div class="content-col"><div class="rule-inner"><span class="rule-line"></span><span class="rule-glyph">✦</span><span class="rule-line"></span></div></div></div>`;
    html += `<div class="article-body page-wrap"><div class="content-col"><div class="prose">${bodyHtml}</div></div></div>`;

    if (inlineMedia.length > 0) {
      html += `<div class="article-images page-wrap"><div class="content-col"><div class="image-grid">`;
      for (const m of inlineMedia) {
        html += `<figure class="image-grid__item">`;
        if (m.resource_type === "video") {
          html += `<video controls preload="metadata" src="${escapeAttr(m.url)}"></video>`;
        } else {
          html += `<img src="${escapeAttr(m.url)}" alt="${escapeAttr(m.alt_text)}" loading="lazy" />`;
        }
        html += `<figcaption>${escapeHtml(m.alt_text)}</figcaption></figure>`;
      }
      html += `</div></div></div>`;
    }

    html += `</article>`;
    return html;
  }

  function openPreview(): void {
    const title = requireElement<HTMLInputElement>("title").value;
    const description =
      requireElement<HTMLTextAreaElement>("description").value;
    const body = bodyInput.value;
    const media = articleData?.media || [];
    const html = buildPreviewHtml(title, description, body, media);
    previewScroll.innerHTML = html;
    previewScroll.scrollTop = 0;
    draftPreview.classList.remove("is-hidden");
    draftPreview.setAttribute("aria-hidden", "false");
    document.body.classList.add("preview-open");
    previewCloseBtn.focus();
  }

  function closePreview(): void {
    draftPreview.classList.add("is-hidden");
    draftPreview.setAttribute("aria-hidden", "true");
    document.body.classList.remove("preview-open");
    previewBtn.focus();
  }

  function ensureToastStack(): HTMLDivElement {
    let stack = document.getElementById("toast-stack");
    if (!stack) {
      stack = document.createElement("div");
      stack.id = "toast-stack";
      stack.className = "toast-stack";
      document.body.appendChild(stack);
    }
    return stack as HTMLDivElement;
  }

  function showToast(message: string, type: ToastType): void {
    const stack = ensureToastStack();
    stack.innerHTML = `<div class="toast toast--${type}">${message}</div>`;
    stack.classList.add("is-visible");

    if (toastTimer) window.clearTimeout(toastTimer);
    toastTimer = window.setTimeout(() => {
      stack.classList.remove("is-visible");
    }, 2600);
  }

  function syncMediaGallery(media: MediaRecord[]): void {
    currentMedia = Array.isArray(media) ? media : [];
    window.dispatchEvent(
      new CustomEvent("admin-media-sync", {
        detail: { galleryId: "article-edit-media", media: currentMedia },
      }),
    );
  }

  window.addEventListener("admin-media-deleted", (event: Event) => {
    const detail = (event as CustomEvent<MediaDeletedEventDetail>).detail;
    if (detail.galleryId !== "article-edit-media") return;
    currentMedia = currentMedia.filter((item) => item.id !== detail.mediaId);
    showToast("Media deleted successfully.", "success");
  });

  window.addEventListener("admin-media-toast", (event: Event) => {
    const detail = (event as CustomEvent<MediaToastEventDetail>).detail;
    if (detail.galleryId !== "article-edit-media") return;
    showToast(
      detail.message ?? "Something went wrong while deleting media.",
      detail.type === "success" ? "success" : "error",
    );
  });

  previewBtn.addEventListener("click", openPreview);
  previewCloseBtn.addEventListener("click", closePreview);
  document.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.key === "Escape" && !draftPreview.classList.contains("is-hidden")) {
      closePreview();
    }
  });

  // Form submission
  form.addEventListener("submit", async (e: SubmitEvent) => {
    e.preventDefault();

    const title = requireElement<HTMLInputElement>("title").value.trim();
    const body = bodyInput.value.trim();
    const slugField =
      requireElement<HTMLInputElement>("slug-field").value.trim();
    const description =
      requireElement<HTMLTextAreaElement>("description").value.trim() ||
      undefined;
    const status = requireElement<HTMLSelectElement>("status")
      .value as ArticleStatus;
    const categoryId = requireElement<HTMLSelectElement>("category").value;
    const tagsRaw = requireElement<HTMLInputElement>("tags").value;
    const tags = tagsRaw
      .split(",")
      .map((t: string) => t.trim())
      .filter(Boolean);

    if (!title || !body) {
      showToast("Title and body are required.", "error");
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = "Saving…";

    try {
      const payload: ArticleUpdatePayload = {
        title,
        body,
        status,
      };
      if (slugField) payload.slug = slugField;
      if (description) payload.description = description;
      if (tags.length) payload.tags = tags;
      if (categoryId) payload.category_id = Number(categoryId);

      const res = await fetch(`/api/articles/${slug}`, {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });

      if (res.status === 401) {
        window.location.href = "/admin";
        return;
      }

      const data = (await res.json()) as ApiErrorResponse;
      if (!res.ok) {
        showToast(data.error ?? "Failed to save.", "error");
        return;
      }

      showToast("Article saved successfully.", "success");
    } catch (err) {
      showToast("Network error. Please try again.", "error");
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = "Save Changes";
    }
  });

  async function handleDelete(): Promise<void> {
    if (!confirm("Are you sure? This action cannot be undone.")) return;

    deleteBtn.disabled = true;
    deleteBtnPanel.disabled = true;

    try {
      const res = await fetch(`/api/articles/${slug}`, {
        method: "DELETE",
      });

      if (res.status === 401) {
        window.location.href = "/admin";
        return;
      }

      if (!res.ok) {
        const data = (await res.json()) as ApiErrorResponse;
        showToast(data.error ?? "Failed to delete.", "error");
        return;
      }

      showToast("Article deleted. Redirecting…", "success");
      setTimeout(() => {
        window.location.href = "/admin/dashboard";
      }, 1500);
    } catch {
      showToast("Network error. Please try again.", "error");
    } finally {
      deleteBtn.disabled = false;
      deleteBtnPanel.disabled = false;
    }
  }

  deleteBtn.addEventListener("click", handleDelete);
  deleteBtnPanel.addEventListener("click", handleDelete);

  async function loadCategories() {
    try {
      const res = await fetch("/api/categories");
      if (!res.ok) return;
      const data = (await res.json()) as CategoriesResponse;
      const categories = Array.isArray(data.categories) ? data.categories : [];
      const categorySelect = requireElement<HTMLSelectElement>("category");
      categorySelect.innerHTML = `<option value="">Uncategorized</option>`;
      for (const cat of categories) {
        categorySelect.insertAdjacentHTML(
          "beforeend",
          `<option value="${cat.id}">${cat.name}</option>`,
        );
      }
    } catch {
      // Keep it functional even if load fails
    }
  }

  const uploadBtn = document.getElementById(
    "upload-btn",
  ) as HTMLButtonElement | null;
  if (uploadBtn) {
    uploadBtn.addEventListener("click", async () => {
      const fileInput = document.getElementById(
        "img-file",
      ) as HTMLInputElement | null;
      const altInput = document.getElementById(
        "img-alt",
      ) as HTMLInputElement | null;
      const statusDiv = document.getElementById(
        "upload-status",
      ) as HTMLDivElement | null;
      const file = fileInput?.files?.[0];

      if (!file) {
        showToast("Please select a file to upload.", "error");
        return;
      }
      const altText = altInput?.value?.trim() || "";
      if (!altText) {
        showToast("Alt text is required before uploading.", "error");
        return;
      }
      if (!articleId) {
        showToast(
          "Wait for the article to finish loading before uploading.",
          "error",
        );
        return;
      }

      const isVideo = file.type.startsWith("video/");
      if (file.size > (isVideo ? MAX_VIDEO_BYTES : MAX_IMAGE_BYTES)) {
        showToast(
          isVideo
            ? "Video exceeds 100 MB limit."
            : "Image exceeds 10 MB limit. Please optimize before uploading.",
          "error",
        );
        return;
      }

      uploadBtn.disabled = true;
      uploadBtn.textContent = "Uploading…";
      if (statusDiv) statusDiv.textContent = "Uploading…";

      try {
        const dataUri = await new Promise<string>((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = () => {
            if (typeof reader.result === "string") {
              resolve(reader.result);
              return;
            }
            reject(new Error("Failed to read file contents."));
          };
          reader.onerror = reject;
          reader.readAsDataURL(file);
        });

        const res = await fetch("/api/upload", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            file_data: dataUri,
            mime_type: file.type,
            file_size: file.size,
            article_id: String(articleId),
            alt_text: altText,
          }),
        });

        if (res.status === 401) {
          window.location.href = "/admin";
          return;
        }

        const data = (await res.json().catch(() => ({}))) as UploadResponse;
        if (!res.ok) {
          showToast(data.error ?? "Upload failed.", "error");
          if (statusDiv) statusDiv.textContent = "";
          return;
        }

        if (data.media) {
          syncMediaGallery([...currentMedia, data.media]);
        }
        if (altInput) altInput.value = "";
        if (fileInput) fileInput.value = "";
        if (statusDiv) statusDiv.textContent = "";
        showToast("Media uploaded successfully.", "success");
      } catch {
        showToast("Network error during upload.", "error");
        if (statusDiv) statusDiv.textContent = "";
      } finally {
        uploadBtn.disabled = false;
        uploadBtn.textContent = "Upload Media";
      }
    });
  }

  loadArticle();
  loadCategories();
</script>
