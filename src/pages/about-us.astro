---
import BlogLayout from "../layouts/BlogLayout.astro";

const siteUrl = import.meta.env.SITE_URL ?? "";
const canonicalUrl = `${siteUrl}/about-us`;
---

<BlogLayout
  title="About Us — The Happy Feeling Scriptorium"
  description="Learn more about The Happy Feeling Scriptorium and our creative publishing focus for artists, illustrators, and comic creators."
  canonicalUrl={canonicalUrl}
>
  <main class="page-wrap static-page">
    <h1>About Us</h1>
    <p>
      The Happy Feeling Scriptorium is a creative publishing space focused on
      practical insights, craft notes, and visual storytelling for artists,
      illustrators, and comic creators.
    </p>
    <p>
      We share process-driven articles that support consistent making,
      experimentation, and growth across drawing, design, and narrative art.
    </p>
  </main>
</BlogLayout>

<style>
  .static-page {
    max-width: 780px;
    padding-top: 56px;
    padding-bottom: 56px;
  }

  .static-page h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 18px;
    color: var(--text);
  }

  .static-page p {
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 14px;
  }
</style>
