---
import SplashScreen from "../components/SplashScreen";
import BlogLayout from "../layouts/BlogLayout.astro";
import { ensureCategorySchema } from "../lib/categories";
import {
  buildCloudinaryImageSrcset,
  buildCloudinaryImageUrl,
} from "../lib/cloudinary";
import { db } from "../lib/db";
import { getPanelImageMap } from "../lib/panels";

const PRIMARY_CATEGORY_SLUGS = [
  "for-artists",
  "for-illustrators",
  "comic-creators",
];

await ensureCategorySchema();
const panelImages = await getPanelImageMap();

const CLOUD =
  process.env.CLOUDINARY_CLOUD_NAME ??
  import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME;

type PanelSlotKey = "panel-01" | "panel-02" | "panel-03" | "panel-04";

const SLOT_PRESET: Record<PanelSlotKey, "panel-tall" | "panel-wide"> = {
  "panel-01": "panel-tall",
  "panel-02": "panel-tall",
  "panel-03": "panel-wide",
  "panel-04": "panel-tall",
};

const SLOT_WIDTHS: Record<"panel-tall" | "panel-wide", number[]> = {
  "panel-tall": [200, 320, 400],
  "panel-wide": [400, 640, 800],
};

function panelSrc(slot: PanelSlotKey): string | null {
  const entry = panelImages[slot];
  if (!entry.publicId || !CLOUD) return entry.url;
  try {
    return buildCloudinaryImageUrl({
      cloudName: CLOUD,
      publicId: entry.publicId,
      preset: SLOT_PRESET[slot],
    });
  } catch {
    return entry.url;
  }
}

function panelSrcset(slot: PanelSlotKey): string | undefined {
  const entry = panelImages[slot];
  if (!entry.publicId || !CLOUD) return undefined;
  const preset = SLOT_PRESET[slot];
  try {
    return buildCloudinaryImageSrcset({
      cloudName: CLOUD,
      publicId: entry.publicId,
      preset,
      widths: SLOT_WIDTHS[preset],
    });
  } catch {
    return undefined;
  }
}

function panelAlt(slot: PanelSlotKey): string {
  const fallbackBySlot: Record<typeof slot, string> = {
    "panel-01": "Featured panel artwork 1",
    "panel-02": "Featured panel artwork 2",
    "panel-03": "Featured panel artwork 3",
    "panel-04": "Splash panel artwork",
  };

  const candidate = panelImages[slot].altText?.trim();
  return candidate && candidate.length > 0 ? candidate : fallbackBySlot[slot];
}

const categoryCountResult = await db.execute(
  `SELECT c.slug, COUNT(a.id) AS article_count
   FROM categories c
   LEFT JOIN articles a ON a.category_id = c.id AND a.status = 'published'
   WHERE c.slug IN (?, ?, ?)
   GROUP BY c.slug`,
  PRIMARY_CATEGORY_SLUGS,
);

const publishedCountByCategory = Object.fromEntries(
  PRIMARY_CATEGORY_SLUGS.map((slug) => [slug, 0]),
) as Record<string, number>;

for (const row of categoryCountResult.rows) {
  const slug = String(row.slug);
  if (slug in publishedCountByCategory) {
    publishedCountByCategory[slug] = Number(row.article_count ?? 0);
  }
}

function formatArticleCount(count: number): string {
  return `${count} ${count === 1 ? "article" : "articles"}`;
}
---

<BlogLayout
  title="Happy Feeling Scriptorium — Art. Comics. Illustration."
  description="ChipsXP Proudly Presents: A creative blog for artists, illustrators, comic creators, and superhero portrait artists."
>
  <!-- Splash screen — client-only React island -->
  <SplashScreen
    client:only="react"
    panelImageUrl={panelSrc("panel-04") ?? undefined}
    panelImageAlt={panelAlt("panel-04")}
  />

  <!-- ─── Hero diptych ─── -->
  <section class="hero">
    <div class="hero__left">
      <span class="hero__eyebrow">ChipsXP Proudly Presents</span>
      <h2 class="hero__title">
        <span class="hero__title-the">The</span>
        Happy Feeling Scriptorium
      </h2>
      <p class="hero__sub">
        A creative home for artists, illustrators,<br />
        comic creators, and superhero portrait artists.
      </p>
      <a href="/blog" class="hero__cta">Read the Archive →</a>
    </div>

    <div class="hero__right">
      <div class="panel-deco">
        {/* Panel 01 — top-left */}
        {
          panelImages["panel-01"].url ? (
            <div class="panel-deco__frame panel-deco__frame--has-image">
              <img
                class="panel-deco__img"
                src={panelSrc("panel-01")!}
                srcset={panelSrcset("panel-01")}
                sizes="(max-width: 768px) 50vw, 320px"
                alt={panelAlt("panel-01")}
                loading="eager"
              />
              <div
                class="panel-deco__inner"
                style="position:relative;z-index:1"
              >
                <span class="panel-deco__label">Panel&nbsp;01</span>
                <span class="panel-deco__impact">POW!</span>
              </div>
            </div>
          ) : (
            <div class="panel-deco__frame">
              <div class="panel-deco__inner">
                <span class="panel-deco__label">Panel&nbsp;01</span>
                <span class="panel-deco__impact">POW!</span>
              </div>
            </div>
          )
        }

        {/* Panel 02 — top-right (kirby blue + dots when no image) */}
        {
          panelImages["panel-02"].url ? (
            <div class="panel-deco__frame panel-deco__frame--has-image">
              <img
                class="panel-deco__img"
                src={panelSrc("panel-02")!}
                srcset={panelSrcset("panel-02")}
                sizes="(max-width: 768px) 50vw, 320px"
                alt={panelAlt("panel-02")}
                loading="eager"
              />
              <div
                class="panel-deco__inner panel-deco__inner--b"
                style="position:relative;z-index:1"
              >
                <span class="panel-deco__bop">BOP!</span>
                <span class="panel-deco__label">Panel&nbsp;02</span>
              </div>
            </div>
          ) : (
            <div class="panel-deco__frame panel-deco__frame--b">
              <div class="panel-deco__inner panel-deco__inner--b">
                <span class="panel-deco__bop">BOP!</span>
                <span class="panel-deco__label">Panel&nbsp;02</span>
              </div>
            </div>
          )
        }

        {
          /* Panel 03 — bottom wide (spans 2 cols; --c preserved for grid-column) */
        }
        {
          panelImages["panel-03"].url ? (
            <div class="panel-deco__frame panel-deco__frame--c panel-deco__frame--has-image">
              <img
                class="panel-deco__img"
                src={panelSrc("panel-03")!}
                srcset={panelSrcset("panel-03")}
                sizes="(max-width: 768px) 100vw, 640px"
                alt={panelAlt("panel-03")}
                loading="eager"
              />
              <div
                class="panel-deco__inner panel-deco__inner--c"
                style="position:relative;z-index:1"
              >
                <span class="panel-deco__label">Panel&nbsp;03</span>
                <span class="panel-deco__zap">ZAP!</span>
              </div>
            </div>
          ) : (
            <div class="panel-deco__frame panel-deco__frame--c">
              <div class="panel-deco__inner panel-deco__inner--c">
                <span class="panel-deco__label">Panel&nbsp;03</span>
                <span class="panel-deco__zap">ZAP!</span>
              </div>
            </div>
          )
        }
      </div>
    </div>
  </section>

  <!-- ─── Panel grid — three pillars ─── -->
  <section class="pillars">
    <div class="pillars__grid">
      <article class="pillar">
        <div class="pillar__accent-strip"></div>
        <div class="pillar__body">
          <span class="pillar__eyebrow">Chapter I</span>
          <div class="pillar__icon" aria-hidden="true">✏️</div>
          <h3 class="pillar__heading">For Artists</h3>
          <p class="pillar__count">
            {formatArticleCount(publishedCountByCategory["for-artists"])}
          </p>
          <p class="pillar__copy">
            Technique deep-dives, studio process, material reviews, and the raw
            honesty of making art every day.
          </p>
          <a href="/blog?category=for-artists" class="pillar__link">Explore →</a
          >
        </div>
      </article>

      <article class="pillar pillar--center">
        <div class="pillar__accent-strip"></div>
        <div class="pillar__body">
          <span class="pillar__eyebrow">Chapter II</span>
          <div class="pillar__icon" aria-hidden="true">🎨</div>
          <h3 class="pillar__heading">For Illustrators</h3>
          <p class="pillar__count">
            {formatArticleCount(publishedCountByCategory["for-illustrators"])}
          </p>
          <p class="pillar__copy">
            Sequential storytelling, panel composition, character design sheets,
            and the grammar of the comic page.
          </p>
          <a href="/blog?category=for-illustrators" class="pillar__link"
            >Explore →</a
          >
        </div>
      </article>

      <article class="pillar">
        <div class="pillar__accent-strip"></div>
        <div class="pillar__body">
          <span class="pillar__eyebrow">Chapter III</span>
          <div class="pillar__icon" aria-hidden="true">🦸</div>
          <h3 class="pillar__heading">For Comic Creators</h3>
          <p class="pillar__count">
            {formatArticleCount(publishedCountByCategory["comic-creators"])}
          </p>
          <p class="pillar__copy">
            Action portrait breakdowns, dynamic pose studies, color theory for
            capes and cowls, and origin story craft.
          </p>
          <a href="/blog?category=comic-creators" class="pillar__link"
            >Explore →</a
          >
        </div>
      </article>
    </div>
  </section>

  <!-- ─── Contributor join strip ─── -->
  {!Astro.locals.user && (
    <section class="join-strip">
      <div class="join-strip__inner">
        <div class="join-strip__copy">
          <span class="join-strip__label">Become a Contributor</span>
          <p class="join-strip__text">
            Artists, illustrators, and comic creators — share your work, process, and stories with the community.
          </p>
        </div>
        <div class="join-strip__actions">
          <a href="/register" class="join-strip__btn join-strip__btn--primary">Create Account →</a>
          <a href="/admin" class="join-strip__btn join-strip__btn--secondary">Sign In →</a>
        </div>
      </div>
    </section>
  )}

  <!-- ─── Manifesto strip ─── -->
  <section class="manifesto">
    <div class="manifesto__inner">
      <blockquote class="manifesto__quote">
        &ldquo;Every panel is a world.<br />Every brushstroke, a
        statement.&rdquo;
      </blockquote>
      <a href="/blog" class="manifesto__cta">Start Reading →</a>
    </div>
  </section>
</BlogLayout>

<style>
  @import "../styles/pages/home.css";
</style>
