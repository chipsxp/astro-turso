---
export interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogType?: "website" | "article";
  ogImage?: string;       // full HTTPS URL to cover image
  ogImageAlt?: string;
  ogImageWidth?: number;  // pixels — required for no-layout-shift on first share
  ogImageHeight?: number;
  ogImageType?: string;   // MIME type, e.g. "image/jpeg"
  publishedTime?: string; // ISO 8601 — article only
  modifiedTime?: string;  // ISO 8601 — article only
  author?: string;        // article only
  section?: string;       // category name — article only
  tags?: string[];        // article tags — emits one article:tag per entry
  locale?: string;        // defaults to "en_US"
  fbAppId?: string;       // optional — unlocks Facebook Insights analytics
  siteName?: string;
}

const {
  title,
  description,
  canonicalUrl,
  ogType = "website",
  ogImage,
  ogImageAlt,
  ogImageWidth,
  ogImageHeight,
  ogImageType = "image/jpeg",
  publishedTime,
  modifiedTime,
  author,
  section,
  tags = [],
  locale = "en_US",
  fbAppId,
  siteName = "The Happy Feeling Scriptorium",
} = Astro.props;

const fullTitle = title.includes(siteName) ? title : `${title} — ${siteName}`;
---

<!-- Primary meta -->
<title>{fullTitle}</title>
{description && <meta name="description" content={description} />}
{canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

<!-- Open Graph — required -->
<meta property="og:site_name" content={siteName} />
<meta property="og:title" content={title} />
<meta property="og:type" content={ogType} />
<meta property="og:locale" content={locale} />
{canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
{description && <meta property="og:description" content={description} />}

<!-- Open Graph — image (structured for no-layout-shift) -->
{ogImage && <meta property="og:image" content={ogImage} />}
{ogImage && <meta property="og:image:secure_url" content={ogImage} />}
{ogImage && <meta property="og:image:type" content={ogImageType} />}
{ogImage && ogImageWidth && <meta property="og:image:width" content={String(ogImageWidth)} />}
{ogImage && ogImageHeight && <meta property="og:image:height" content={String(ogImageHeight)} />}
{ogImage && ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}

<!-- Article object tags (ogp.me article type) -->
{ogType === "article" && publishedTime && (
  <meta property="article:published_time" content={publishedTime} />
)}
{ogType === "article" && modifiedTime && (
  <meta property="article:modified_time" content={modifiedTime} />
)}
{ogType === "article" && author && (
  <meta property="article:author" content={author} />
)}
{ogType === "article" && section && (
  <meta property="article:section" content={section} />
)}
{ogType === "article" && tags.map((tag) => (
  <meta property="article:tag" content={tag} />
))}

<!-- Facebook Insights (optional — only emitted when fb:app_id env var is set) -->
{fbAppId && <meta property="fb:app_id" content={fbAppId} />}

<!-- Twitter / X Card -->
<meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
<meta name="twitter:title" content={title} />
{description && <meta name="twitter:description" content={description} />}
{ogImage && <meta name="twitter:image" content={ogImage} />}
{ogImage && ogImageAlt && (
  <meta name="twitter:image:alt" content={ogImageAlt} />
)}
