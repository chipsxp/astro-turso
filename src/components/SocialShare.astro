---
export interface Props {
  title: string;
  url: string; // full canonical URL of the article
  description?: string;
  image?: string; // cover image URL — used by Pinterest
  tags?: string[]; // article tags → hashtags for X
  authorId?: number; // if omitted with articleId, panel is always public
  articleId?: number; // if omitted, share events are not logged
}

const {
  title,
  url,
  description,
  image = "",
  tags = [],
  authorId,
  articleId,
} = Astro.props;

// Public when no authorId and no articleId (events, shop). Auth-gated for articles.
const isPublic = authorId == null && articleId == null;
const user = Astro.locals.user;
const isAuthorized =
  isPublic ||
  (user != null &&
    (user.role === "admin" ||
      (authorId != null && String(user.id) === String(authorId))));

// ── Build encoded share parameters ──────────────────────────────────────────
const enc = encodeURIComponent;

const hashtags = tags
  .map((t) => t.replace(/\s+/g, ""))
  .filter(Boolean)
  .slice(0, 5) // X caps hashtag count at ~5 before truncation
  .join(",");

const shareText = enc(`${title} ${url}`);
const tweetText = enc(title);
const encodedUrl = enc(url);
const encodedTitle = enc(title);
const encodedDesc = enc(description ?? title);
const encodedImage = image ? enc(image) : "";

// ── Platform definitions ─────────────────────────────────────────────────────
interface Platform {
  id: string;
  label: string;
  color: string; // brand hover color
  method: "intent" | "clipboard";
  shareUrl?: string; // method=intent
  clipboardText?: string; // method=clipboard
  openUrl?: string; // method=clipboard — opens after copy
  svg: string; // inner SVG markup (paths)
}

