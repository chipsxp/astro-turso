---

{
  isAuthorized && (
    <div
      id="share-panel"
      class="share-panel share-panel--visible"
      data-article-id={articleId != null ? String(articleId) : ""}
      aria-hidden="false"
      aria-label="Share this content"
    >
      <div class="share-panel__header">
        <span class="share-panel__title">Share</span>
        <span class="share-panel__hint">
          Click any platform to share immediately
        </span>
      </div>

      <div
        class="share-panel__grid"
        role="group"
        aria-label="Share to a platform"
      >
        {platforms.map((p) => (
          <button
            type="button"
            class={`share-btn share-btn--${p.id}`}
            data-platform={p.id}
            data-method={p.method}
            data-share-url={p.shareUrl ?? ""}
            data-clipboard-text={p.clipboardText ?? ""}
            data-open-url={p.openUrl ?? ""}
            data-color={p.color}
            data-label={p.label}
            aria-label={
              p.method === "intent"
                ? `Share on ${p.label}`
                : `Copy link and open ${p.label}`
            }
          >
            <svg
              viewBox="0 0 24 24"
              width="14"
              height="14"
              fill="currentColor"
              aria-hidden="true"
            >
              <Fragment set:html={p.svg} />
            </svg>
            <span class="share-btn__label">{p.label}</span>
          </button>
        ))}
      </div>

      <p
        id="share-clipboard-tip"
        class="share-clipboard-tip"
        role="status"
        aria-live="polite"
      />
    </div>
  )
}

<style>
  @import "../styles/components/social-share.css";
</style>

<script>
  (function () {
    // ── Auth gate ──────────────────────────────────────────────────────────────

    const panel = document.getElementById(
      "share-panel",
    ) as HTMLDivElement | null;
    if (!panel) return; // panel is intentionally absent for non-authorized visitors

    const articleId = Number(panel.dataset.articleId ?? "0");

    // ── UI helpers ─────────────────────────────────────────────────────────────

    const tipEl = document.getElementById(
      "share-clipboard-tip",
    ) as HTMLParagraphElement;

    function showTip(msg: string): void {
      tipEl.textContent = msg;
      tipEl.classList.add("share-clipboard-tip--visible");
      setTimeout(() => {
        tipEl.textContent = "";
        tipEl.classList.remove("share-clipboard-tip--visible");
      }, 4000);
    }

    function flashButton(btn: HTMLButtonElement, label: string): void {
      const labelEl = btn.querySelector<HTMLSpanElement>(".share-btn__label");
      if (!labelEl) return;
      const original = labelEl.textContent ?? label;
      btn.classList.add("share-btn--done");
      labelEl.textContent = "Shared!";
      setTimeout(() => {
        btn.classList.remove("share-btn--done");
        labelEl.textContent = original;
      }, 2000);
    }

    // ── Share analytics logger ─────────────────────────────────────────────────

    async function logShare(platform: string): Promise<void> {
      if (!articleId) return; // no logging for events/shop (no articleId)
      try {
        await fetch("/api/share", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({ article_id: articleId, platform }),
        });
      } catch {
        // Analytics failure must never block the share action
      }
    }

    // ── Apply brand colors from data-color attribute ───────────────────────────

    const shareBtns = panel.querySelectorAll<HTMLButtonElement>(".share-btn");

    shareBtns.forEach((btn) => {
      const color = btn.dataset.color;
      if (color) btn.style.setProperty("--btn-brand-color", color);
    });

    const controller = new AbortController();

    shareBtns.forEach((btn) => {
      btn.addEventListener(
        "click",
        async () => {
          const method = btn.dataset.method;
          const platform = btn.dataset.platform ?? "";
          const label = btn.dataset.label ?? platform;

          if (method === "intent") {
            const shareUrl = btn.dataset.shareUrl;
            if (!shareUrl) return;
            void logShare(platform);
            window.open(
              shareUrl,
              "_blank",
              "width=600,height=500,noopener,noreferrer",
            );
            flashButton(btn, label);
          } else if (method === "clipboard") {
            const text = btn.dataset.clipboardText ?? "";
            const openUrl = btn.dataset.openUrl ?? "";
            void logShare(platform);

            try {
              await navigator.clipboard.writeText(text);
              showTip(`Link copied for ${label} — paste it in your new post.`);
            } catch {
              showTip(
                `Could not auto-copy for ${label} — copy the URL manually.`,
              );
            }

            if (openUrl) {
              window.open(openUrl, "_blank", "noopener,noreferrer");
            }

            flashButton(btn, label);
          }
        },
        { signal: controller.signal },
      );
    });
  })();
</script>
